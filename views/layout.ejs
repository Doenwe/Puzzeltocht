<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Puzzeltocht</title>

  <!-- TailwindCSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    :root{
      --primary: <%= theme?.primaryColor || '#2563eb' %>;
      --bg: <%= theme?.backgroundColor || '#ffffff' %>;
      --text: <%= theme?.textColor || '#111827' %>;
      --radius: <%= theme?.borderRadius || '0.75rem' %>;
      --font: <%= theme?.fontFamily || 'Inter, ui-sans-serif, system-ui' %>;
    }
    body{
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
    }
    .btn-primary{
      background: var(--primary);
      color: #fff;
      border-radius: var(--radius);
    }
    .card{
      background: #ffffffcc;
      backdrop-filter: blur(6px);
      border-radius: var(--radius);
    }
    a.link { color: var(--primary); }
  </style>
</head>

<body class="min-h-screen">

  <!-- Navigatie -->
  <header class="sticky top-0 z-30 bg-white/80 backdrop-blur border-b">
    <nav class="mx-auto max-w-md px-4 h-14 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg">Puzzeltocht</a>
      <div class="flex items-center gap-3 text-sm">
        <% if (session?.isAdmin) { %>
          <a class="link" href="/admin-dashboard">Dashboard</a>
          <a class="link" href="/admin-logout">Logout</a>
        <% } else { %>
          <a class="link" href="/admin-login">Admin</a>
        <% } %>
      </div>
    </nav>
  </header>

  <!-- Pagina-inhoud -->
  <% if (typeof builderPage !== "undefined" && builderPage === true) { %>

      <!-- BUILDER FULL WIDTH -->
      <main class="w-full h-[calc(100vh-56px)] p-0 m-0">
        <%- body %>
      </main>

  <% } else { %>

      <!-- STANDAARD PAGINA (max 450px breed) -->
      <main class="mx-auto max-w-md px-4 py-6">
        <%- body %>
      </main>

  <% } %>

  <script src="/app.js"></script>
</body>
</html>
