<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= puzzle.name %> — <%= page.title %></title>

  <style>
    body {
      font-family: system-ui, sans-serif;
      background: #f5f7fa;
      padding: 24px;
      margin: 0;
    }

    .card {
      background: #fff;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .btn {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 8px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-size: 15px;
    }

    .btn.secondary {
      background: #334155;
      margin-top: 24px;
    }

    .feedback {
      margin-top: 8px;
      font-weight: 600;
    }

    label {
      display: flex;
      gap: 8px;
      margin-top: 6px;
      cursor: pointer;
      align-items: center;
    }

    /* Image viewer */
    .img-thumb {
      max-width: 100%;
      border-radius: 8px;
      cursor: zoom-in;
    }

    .img-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.75);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .img-overlay img {
      max-width: 90%;
      max-height: 90%;
      border-radius: 12px;
    }

    /* Map */
    #map {
      height: 300px;
      border-radius: 12px;
    }
  </style>
</head>

<body>

<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<% /* ===================== MAP PAGINA ===================== */ %>
<% if (page.isMap) { %>
  <div class="card">
    <div id="map"></div>
    <p class="feedback" id="mapFeedback"></p>
  </div>
<% } %>

<% /* ===================== MODULES ===================== */ %>
<% (page.modules || []).forEach((mod, qIndex) => { %>

  <% if (mod.type === "text") { %>
    <div class="card"><%- mod.data?.text || "" %></div>
  <% } %>

  <% if (mod.type === "image") { %>
    <div class="card">
      <img
        src="<%= mod.data.url %>"
        alt=""
        class="img-thumb"
        onclick="openImage(this.src)">
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <div class="card">
      <strong><%= mod.data.question %></strong>

      <% if (mod.data.questionType === "mc") { %>
        <div
          data-mc
          data-options='<%- JSON.stringify(mod.data.options || []) %>'
          data-good="<%= mod.data.goodPage ?? '' %>"
          data-bad="<%= mod.data.badPage ?? '' %>"
          data-puzzle="<%= puzzle._id %>"
        >
          <% mod.data.options.forEach((o,i)=>{ %>
            <label>
              <input type="radio" name="mc-<%= qIndex %>" value="<%= i %>">
              <%= o.text %>
            </label>
          <% }) %>

          <button class="btn" onclick="handleMC(this)">Controleer</button>
          <div class="feedback"></div>
        </div>
      <% } else { %>
        <form onsubmit="return handleOpen(event,this)">
          <input name="answer" placeholder="Jouw antwoord">
          <button class="btn">Controleer</button>
          <div class="feedback"></div>

          <input type="hidden" name="correct" value="<%= mod.data.answer %>">
          <input type="hidden" name="good" value="<%= mod.data.goodPage ?? '' %>">
          <input type="hidden" name="bad" value="<%= mod.data.badPage ?? '' %>">
          <input type="hidden" name="puzzle" value="<%= puzzle._id %>">
        </form>
      <% } %>
    </div>
  <% } %>

<% }) %>

<%
  const hasNext =
    page.showNext &&
    pageIndex + 1 < puzzle.pages.length;
%>

<% if (hasNext) { %>
  <a class="btn secondary"
     href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
    Volgende pagina →
  </a>
<% } %>

<!-- IMAGE OVERLAY -->
<div class="img-overlay" id="imgOverlay" onclick="this.style.display='none'">
  <img id="overlayImg">
</div>

<script>
/* ========== AUDIO ON START ========== */
<% if (page.playSoundOnStart && page.soundUrl) { %>
  const audio = new Audio("<%= page.soundUrl %>");
  audio.play().catch(()=>{});
<% } %>

/* ========== AUTO NEXT ========== */
<% if (page.autoNext && pageIndex + 1 < puzzle.pages.length) { %>
  setTimeout(()=>{
    location.href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>";
  }, 2000);
<% } %>

/* ========== IMAGE VIEWER ========== */
function openImage(src) {
  document.getElementById("overlayImg").src = src;
  document.getElementById("imgOverlay").style.display = "flex";
}

/* ========== QUESTIONS ========== */
function handleMC(btn) {
  const b = btn.closest('[data-mc]');
  const fb = b.querySelector('.feedback');
  const r = b.querySelector('input:checked');
  if (!r) return fb.textContent = "Kies een antwoord.";

  const opts = JSON.parse(b.dataset.options);
  const ok = !!opts[r.value]?.correct;
  const go = ok ? b.dataset.good : b.dataset.bad;

  if (go !== "") {
    location.href = `/puzzle/${b.dataset.puzzle}/${go}`;
    return;
  }
  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
}

function handleOpen(e,f) {
  e.preventDefault();
  const ok = f.answer.value.trim().toLowerCase()
           === f.correct.value.trim().toLowerCase();
  const go = ok ? f.good.value : f.bad.value;
  if (go !== "") {
    location.href = `/puzzle/${f.puzzle.value}/${go}`;
    return false;
  }
  const fb=f.querySelector('.feedback');
  fb.textContent = ok?"Goed!":"Fout!";
  fb.style.color = ok?"green":"red";
  return false;
}
</script>

</body>
</html>
