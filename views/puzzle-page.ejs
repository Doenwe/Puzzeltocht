<%
  const hasNext  = !!puzzle.pages[pageIndex + 1];
  const showNext = (typeof page?.showNext === 'boolean') ? page.showNext : true;
  const isMap    = (typeof page?.isMap === 'boolean')    ? page.isMap    : false;

  const showTarget       = (typeof page?.showTarget === 'boolean') ? page.showTarget : true;
  const autoNext         = (typeof page?.autoNext   === 'boolean') ? page.autoNext   : false;

  // BELANGRIJK: hernoemd → geen conflict met functie!
  const shouldPlaySound  = (typeof page?.playSound === 'boolean') ? page.playSound  : false;

  const soundUrl         = page?.soundUrl || "";
%>

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= puzzle.name %> — <%= page.title %></title>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    :root{
      --primary:#2563eb;
      --text:#111827;
      --muted:#6b7280;
      --card:#ffffff;
      --border:#e5e7eb;
    }

    body{
      margin:0;
      font-family:Inter,system-ui;
      color:var(--text);
      background:#f8fafc;
    }

    .container{
      max-width:880px;
      margin:0 auto;
      padding:16px;
      display:grid;
      gap:16px;
    }

    h1,h2{margin:0;}

    .card{
      background:#fff;
      border:1px solid var(--border);
      border-radius:14px;
      padding:16px;
      box-shadow:0 3px 10px rgba(0,0,0,0.05);
    }

    #map{
      height:65vh;
      min-height:380px;
      border-radius:14px;
      border:1px solid var(--border);
      overflow:hidden;
    }

    .next-btn{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      background:var(--primary);
      color:white;
      border-radius:10px;
      text-decoration:none;
      font-weight:600;
    }

    .muted{ color:var(--muted); }

    .grid{ display:grid; gap:16px; }
  </style>
</head>

<body>

<!-- ★ PERSISTENTE GLOBAL AUDIOPLAYER ★ -->
<audio id="global-sound-player" preload="auto" style="display:none;"></audio>

<!-- iOS/Android vereiste audio unlock -->
<button id="audio-unlock" style="opacity:0; position:absolute; pointer-events:none;">unlock</button>

<div class="container">

  <h1><%= puzzle.name %></h1>
  <h2><%= page.title %></h2>

  <% if (isMap) { %>
    <!-- MAP PAGINA -->
    <div class="card" style="padding:0;">
      <div id="map"></div>
    </div>
  <% } else { %>

    <!-- MODULE PAGINA -->
    <div class="grid">
      <% (page.modules || []).forEach(mod => { %>

        <% if (mod.type === "text") { %>
          <div class="card"><%- mod.data?.text || "" %></div>
        <% } %>

        <% if (mod.type === "image") { %>
          <div class="card" style="padding:0;">
            <% if (mod.data?.url) { %>
              <img src="<%= mod.data.url %>" style="width:100%; border-radius:14px;">
            <% } else { %>
              <div class="muted" style="padding:12px;">Geen afbeelding opgegeven.</div>
            <% } %>
          </div>
        <% } %>

        <% if (mod.type === "question") { %>
          <div class="card">
            <p><%= mod.data?.question %></p>

            <form
              onsubmit="return checkAnswerBranch(
                this,
                '<%= (mod.data?.answer||'').replace(/"/g,'&quot;') %>',
                <%= Number.isInteger(mod.data?.goodPage)? mod.data.goodPage : 'null' %>,
                <%= Number.isInteger(mod.data?.badPage)?  mod.data.badPage  : 'null' %>,
                '<%= puzzle._id %>'
              )">

              <input type="text" name="answer" placeholder="Jouw antwoord">
              <button class="next-btn" type="submit">Controleer</button>
              <div data-feedback style="margin-top:8px;"></div>
            </form>
          </div>
        <% } %>

      <% }) %>
    </div>

  <% } %>

  <% if (hasNext && showNext) { %>
    <a class="next-btn" href="/puzzle/<%= puzzle._id %>/<%= pageIndex+1 %>">
      Volgende pagina ➜
    </a>
  <% } %>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
/* ===========================================================
   VRAAGMODULE
   =========================================================== */
function normalize(str){
  return String(str||"")
    .trim().toLowerCase()
    .normalize("NFKD").replace(/[\u0300-\u036f]/g,"")
    .replace(/\s+/g," ");
}

function checkAnswerBranch(form, correct, goodPage, badPage, puzzleId){
  const fb = form.querySelector("[data-feedback]");
  const ok = normalize(form.answer.value) === normalize(correct);

  if (ok && Number.isInteger(goodPage)){
    window.location.href = `/puzzle/${puzzleId}/${goodPage}`;
    return false;
  }
  if (!ok && Number.isInteger(badPage)){
    window.location.href = `/puzzle/${puzzleId}/${badPage}`;
    return false;
  }

  fb.textContent = ok ? "✅ Klopt!" : "❌ Niet goed";
  fb.style.color = ok ? "#059669" : "#dc2626";
  return false;
}


/* ===========================================================
   GLOBAL AUDIO ENGINE (PERSISTENT OVER PAGINA'S)
   =========================================================== */
const audioPlayer = document.getElementById("global-sound-player");

// iOS/Android audio unlock
function unlockAudio(){
  audioPlayer.play().then(() => {
    audioPlayer.pause();
    audioPlayer.currentTime = 0;
    console.log("AUDIO UNLOCKED");
  }).catch(()=>{});
}

document.body.addEventListener("touchstart", unlockAudio, { once:true });
document.body.addEventListener("click", unlockAudio, { once:true });

// preload audio op pagina load
window.addEventListener("load", () => {
  if ("<%= soundUrl %>".trim()) {
    audioPlayer.src = "<%= soundUrl %>";
    audioPlayer.load();
  }
});

// veilige audiostart
function playSfx(url){
  if (!url) return;
  audioPlayer.src = url;
  audioPlayer.currentTime = 0;
  audioPlayer.play().catch(()=>{});
}



/* ===========================================================
   MAP + AUTONEXT MET AUDIO (optie A)
   =========================================================== */
(function initMap(){
  const mapEl = document.getElementById("map");
  if (!mapEl) return;

  const targetLat    = <%= page.targetLat ?? 'null' %>;
  const targetLng    = <%= page.targetLng ?? 'null' %>;
  const targetRadius = <%= page.targetRadius ?? 50 %>;
  const showTarget   = <%= showTarget ? 'true' : 'false' %>;
  const autoNext     = <%= autoNext ? 'true' : 'false' %>;
  const shouldPlay   = <%= shouldPlaySound ? 'true' : 'false' %>;
  const soundUrl     = "<%= soundUrl %>";
  const hasNextPage  = <%= hasNext ? 'true' : 'false' %>;
  const nextUrl      = "/puzzle/<%= puzzle._id %>/<%= pageIndex+1 %>";

  let isRedirecting = false;

  const map = L.map("map").setView([52,5], 7);
  L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom:19 }).addTo(map);

  const hasTarget = (targetLat !== null && targetLng !== null);

  if (hasTarget && showTarget){
    const circle = L.circle([targetLat,targetLng], {
      radius:targetRadius, color:"#ef4444", fillColor:"#ef4444", fillOpacity:0.2
    }).addTo(map);

    L.marker([targetLat,targetLng]).addTo(map);
    map.fitBounds(circle.getBounds(), { padding:[20,20] });
  }

  let userMarker = null;

  function onLocationFound(e){
    const pos = e.latlng;

    if (!userMarker){
      userMarker = L.marker(pos).addTo(map);
    } else {
      userMarker.setLatLng(pos);
    }

    if (!hasTarget) return;

    const dist = pos.distanceTo([targetLat,targetLng]);

    if (
      autoNext &&
      hasNextPage &&
      !isRedirecting &&
      dist <= Number(targetRadius)
    ){
      isRedirecting = true;

      // ★ GELUID STARTEN (blijft spelen bij paginawissel!)
      if (shouldPlay && soundUrl.trim()){
        playSfx(soundUrl);
      }

      // korte delay om audio *te laten starten*
      setTimeout(() => {
        window.location.href = nextUrl;
      }, 300);
    }
  }

  map.locate({ watch:true, enableHighAccuracy:true })
     .on("locationfound", onLocationFound);

})();
</script>

</body>
</html>
