<%
  const hasNext  = !!puzzle.pages[pageIndex + 1];
  const showNext = page?.showNext ?? true;
  const isMap    = page?.isMap    ?? false;

  const showTarget      = page?.showTarget ?? true;
  const autoNext        = page?.autoNext   ?? false;
  const shouldPlaySound = page?.playSound  ?? false;
  const soundUrl        = page?.soundUrl   || "";
%>

<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title><%= puzzle.name %> — <%= page.title %></title>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
:root{
  --primary:#2563eb;
  --text:#111827;
  --muted:#6b7280;
  --card:#ffffff;
  --border:#e5e7eb;
}
body{
  margin:0;
  font-family:Inter,system-ui;
  background:#f8fafc;
  color:var(--text);
}
.container{
  max-width:880px;
  margin:0 auto;
  padding:16px;
  display:grid;
  gap:16px;
}
.card{
  background:#fff;
  border:1px solid var(--border);
  padding:16px;
  border-radius:14px;
  box-shadow:0 3px 10px rgba(0,0,0,0.05);
}
#map{
  height:65vh;
  border-radius:14px;
  border:1px solid var(--border);
}
.next-btn{
  display:inline-flex;
  background:var(--primary);
  color:white;
  padding:10px 14px;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
  gap:5px;
}
.grid{ display:grid; gap:16px; }
.muted{ color:var(--muted); }
</style>
</head>

<body>

<!-- PERSISTENTE AUDIO DIE NIET VERDWIJNT TUSSEN PAGINA'S -->
<audio id="global-sound" preload="auto" style="display:none;"></audio>

<!-- iOS / ANDROID audio unlock -->
<button id="audio-unlock"
  style="opacity:0; position:absolute; pointer-events:none;">unlock</button>

<div class="container">
<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<% if (isMap) { %>

  <div class="card" style="padding:0">
    <div id="map"></div>
  </div>

<% } else { %>

  <div class="grid">

    <% (page.modules || []).forEach(mod => { %>

      <% if (mod.type === "text") { %>
        <div class="card"><%- mod.data?.text %></div>
      <% } %>

      <% if (mod.type === "image") { %>
        <div class="card" style="padding:0;">
          <% if (mod.data?.url) { %>
            <img src="<%= mod.data.url %>" style="width:100%; border-radius:12px;" />
          <% } else { %>
            <div class="muted" style="padding:12px;">Geen afbeelding opgegeven.</div>
          <% } %>
        </div>
      <% } %>

      <% if (mod.type === "question") { %>
        <div class="card">
          <p><%= mod.data?.question %></p>

          <form onsubmit="return checkAnswerBranch(
            this,
            '<%= (mod.data?.answer||'').replace(/"/g,'&quot;') %>',
            <%= Number.isInteger(mod.data?.goodPage) ? mod.data.goodPage : 'null' %>,
            <%= Number.isInteger(mod.data?.badPage)  ? mod.data.badPage  : 'null' %>,
            '<%= puzzle._id %>'
          )">
            <input name="answer" type="text" placeholder="Jouw antwoord">
            <button class="next-btn">Controleer</button>
            <div data-feedback style="margin-top:8px;"></div>
          </form>
        </div>
      <% } %>

    <% }) %>

  </div>

<% } %>

<% if (hasNext && showNext) { %>
  <button class="next-btn" onclick="navigateAjax('/puzzle/<%= puzzle._id %>/<%= pageIndex+1 %>')">
    Volgende pagina ➜
  </button>
<% } %>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
/* =========================================
   AUDIO ENGINE (blijft spelen bij paginawissel!)
   ========================================= */
const audioPlayer = document.getElementById("global-sound");

// iPhone unlock
function unlockAudio(){
  audioPlayer.play().then(()=>{
    audioPlayer.pause();
    audioPlayer.currentTime = 0;
  }).catch(()=>{});
}
document.body.addEventListener("touchstart", unlockAudio, {once:true});
document.body.addEventListener("click", unlockAudio, {once:true});

// preload
window.addEventListener("load", ()=>{
  if ("<%= soundUrl %>".trim()) {
    audioPlayer.src = "<%= soundUrl %>";
    audioPlayer.load();
  }
});

function playSfx(url){
  if (!url) return;
  audioPlayer.src = url;
  audioPlayer.currentTime = 0;
  audioPlayer.play().catch(()=>{});
}


/* =========================================
   AJAX NAVIGATIE (audio blijft spelen)
   ========================================= */
async function navigateAjax(url){
  const res = await fetch(url);
  const html = await res.text();
  document.open();
  document.write(html);
  document.close();
}


/* =========================================
   BRANCHING voor vragen
   ========================================= */
function normalize(s){
  return String(s||"").trim().toLowerCase()
    .normalize("NFKD").replace(/[\u0300-\u036f]/g,"");
}
function checkAnswerBranch(form, correct, goodPage, badPage, pid){
  const fb = form.querySelector("[data-feedback]");
  const ok = normalize(form.answer.value) === normalize(correct);

  if (ok && Number.isInteger(goodPage))
    return navigateAjax(`/puzzle/${pid}/${goodPage}`), false;
  if (!ok && Number.isInteger(badPage))
    return navigateAjax(`/puzzle/${pid}/${badPage}`), false;

  fb.textContent = ok ? "✅ Klopt!" : "❌ Niet goed";
  fb.style.color = ok ? "#059669" : "#dc2626";
  return false;
}


/* =========================================
   MAP + AUTO NEXT
   ========================================= */
(function initMap(){
  const el = document.getElementById("map");
  if (!el) return;

  const targetLat  = <%= page.targetLat ?? 'null' %>;
  const targetLng  = <%= page.targetLng ?? 'null' %>;
  const targetRad  = <%= page.targetRadius ?? 50 %>;
  const showTarget = <%= showTarget ? 'true':'false' %>;
  const autoNext   = <%= autoNext ? 'true':'false' %>;
  const shouldPlay = <%= shouldPlaySound ? 'true':'false' %>;
  const soundUrl   = "<%= soundUrl %>";
  const hasNext    = <%= hasNext ? 'true':'false' %>;
  const nextUrl    = "/puzzle/<%= puzzle._id %>/<%= pageIndex+1 %>";

  let redirecting = false;

  const map = L.map("map").setView([52,5], 7);
  L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {maxZoom:19}).addTo(map);

  const hasTarget = targetLat !== null && targetLng !== null;

  if (hasTarget && showTarget){
    const c = L.circle([targetLat,targetLng], {
      radius:targetRad,
      color:"#ef4444",
      fillColor:"#ef4444",
      fillOpacity:0.2
    }).addTo(map);
    L.marker([targetLat,targetLng]).addTo(map);
    map.fitBounds(c.getBounds(), {padding:[20,20]});
  }

  let userMarker = null;

  function onLocation(e){
    const pos = e.latlng;
    if (!userMarker) userMarker = L.marker(pos).addTo(map);
    else userMarker.setLatLng(pos);

    if (!hasTarget) return;

    const d = pos.distanceTo([targetLat,targetLng]);

    if (
      autoNext &&
      hasNext &&
      !redirecting &&
      d <= Number(targetRad)
    ){
      redirecting = true;

      if (shouldPlay && soundUrl.trim())
          playSfx(soundUrl);

      // navigatie via AJAX → audio blijft doorspelen
      setTimeout(()=>navigateAjax(nextUrl), 200);
    }
  }

  map.locate({watch:true, enableHighAccuracy:true})
     .on("locationfound", onLocation);
})();
</script>

</body>
</html>
