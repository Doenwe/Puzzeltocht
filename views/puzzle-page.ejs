<%
  // Data vanuit de route:
  // puzzle: { _id, name, pages: [...] }
  // page:    puzzle.pages[pageIndex]
  // pageIndex: Number (0-based)

  const hasNext  = !!puzzle.pages[pageIndex + 1];
  const showNext = (typeof page?.showNext === 'boolean') ? page.showNext : true;
  const isMap    = (typeof page?.isMap === 'boolean')    ? page.isMap    : false;
%>

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= puzzle.name %> — <%= page.title %></title>

  <!-- ✅ Leaflet CSS (correct geladen) -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    crossorigin=""
  />

  <style>
    /* Kaartcontainer met stabiele hoogte (mobiel-proof) */
    #map {
      height: 65vh;
      min-height: 380px; /* fallback voor kleine schermen/iOS */
      border-radius: 14px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 10px 24px rgba(0,0,0,.08);
      background: #eef2ff; /* nette kleur totdat tiles laden */
    }
    .leaflet-container { background: #eef2ff; }

    /* Professionele user-dot (Google-achtig) */
    .user-dot {
      width: 14px; height: 14px; border-radius: 50%;
      background: #1a73e8;            /* blauw */
      border: 3px solid #ffffff;      /* witte ring */
      box-shadow: 0 0 0 2px rgba(26,115,232,0.25); /* zachte glow */
    }
    .user-dot.pulse { position: relative; }
    .user-dot.pulse::after {
      content: "";
      position: absolute; left: 50%; top: 50%;
      width: 14px; height: 14px; transform: translate(-50%,-50%);
      border-radius: 50%;
      background: rgba(26,115,232,0.3);
      animation: userDotPulse 2.2s ease-out infinite;
    }
    @keyframes userDotPulse {
      0%   { transform: translate(-50%,-50%) scale(1);   opacity: .6; }
      70%  { transform: translate(-50%,-50%) scale(2.6); opacity: 0; }
      100% { transform: translate(-50%,-50%) scale(2.6); opacity: 0; }
    }

    /* Heading-pijl (optioneel; draait met heading) */
    .heading-arrow {
      width: 0; height: 0;
      border-left: 6px solid transparent;
      border-right: 6px solid transparent;
      border-bottom: 10px solid #1a73e8;
      filter: drop-shadow(0 0 2px rgba(0,0,0,.3));
      transform-origin: 50% 80%;
      position: absolute; top: -14px; left: 50%;
      translate: -50% 0;
    }

    /* Simpele layout (werkt samen met je layout.ejs + Tailwind) */
    .container { display: grid; gap: 1rem; }
    .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 1rem; box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .muted { color: #6b7280; font-size: .9rem; }

    .next-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: #2563eb; color: #fff; padding: 10px 14px;
      border-radius: 10px; border: none; text-decoration: none;
      box-shadow: 0 6px 16px rgba(37,99,235,.25);
    }
    .next-btn:hover { filter: brightness(1.05); }
  </style>
</head>
<body>

<div class="container">

  <div>
    <h1 class="text-2xl font-bold"><%= puzzle.name %></h1>
    <h2 class="text-xl font-semibold"><%= page.title %></h2>
  </div>

  <% if (isMap) { %>
    <!-- ============ KAARTPAGINA ============ -->
    <div id="map"></div>

    <% if (hasNext && showNext) { %>
      <div class="pt-4">
        <a class="next-btn" href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
          <span>Volgende pagina</span> <span aria-hidden="true">➜</span>
        </a>
      </div>
    <% } %>

  <% } else { %>
    <!-- ============ NORMALE PAGINA (modules) ============ -->
    <div class="grid" style="display:grid; gap: 1rem;">
      <% (page.modules || []).forEach((mod) => { %>

        <% if (mod.type === "text") { %>
          <div class="card">
            <!-- Builder slaat HTML op -->
            <%- mod.data?.text || "" %>
          </div>
        <% } %>

        <% if (mod.type === "image") { %>
          <div class="card" style="padding:0;">
            <% if (mod.data?.url) { %>
              <img src="<%= mod.data.url %>" alt="" style="width:100%; display:block; border-radius:12px;" />
            <% } else { %>
              <div class="muted" style="padding:1rem;">Geen afbeelding opgegeven.</div>
            <% } %>
          </div>
        <% } %>

        <% if (mod.type === "question") { %>
          <div class="card" style="display:grid; gap:.5rem;">
            <p class="font-semibold"><%= mod.data?.question || "Vraag" %></p>

            <form
              onsubmit="return checkAnswerBranch(
                this,
                '<%= (mod.data?.answer ? String(mod.data.answer).replace(/"/g,'&quot;') : '') %>',
                <%= (Number.isInteger(mod.data?.goodPage) ? mod.data.goodPage : 'null') %>,
                <%= (Number.isInteger(mod.data?.badPage)  ? mod.data.badPage  : 'null') %>,
                '<%= puzzle._id %>'
              )"
              style="display:grid; gap:.5rem;"
            >
              <input
                type="text"
                name="answer"
                placeholder="Jouw antwoord"
                class="border p-2 rounded w-full"
                autocomplete="off"
                style="border:1px solid #e5e7eb; border-radius:10px; padding:10px;"
              />
              <div class="flex gap-2">
                <button class="next-btn" type="submit">Controleer</button>
              </div>
              <div class="text-sm" data-feedback></div>
            </form>
          </div>
        <% } %>

        <% if (mod.type === "location") { %>
          <div class="card" style="display:grid; gap:.25rem;">
            <p class="font-semibold">Locatie‑check</p>
            <p class="muted">Lat: <%= (mod.data?.lat ?? "?") %></p>
            <p class="muted">Lng: <%= (mod.data?.lng ?? "?") %></p>
            <p class="muted">Straal: <%= (mod.data?.radius ?? 50) %> meter</p>
          </div>
        <% } %>

      <% }) %>
    </div>

    <% if (hasNext && showNext) { %>
      <div class="pt-4">
        <a class="next-btn" href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
          <span>Volgende pagina</span> <span aria-hidden="true">➜</span>
        </a>
      </div>
    <% } %>
  <% } %>

</div>

<!-- ✅ Leaflet JS (correct geladen, NA de HTML) -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script>
  // ===== Branching voor vraag‑blokken =====
  function normalize(str){
    return String(str||'')
      .trim()
      .toLowerCase()
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g,'')
      .replace(/\s+/g,' ');
  }
  function checkAnswerBranch(form, correct, goodPage, badPage, puzzleId){
    const feedback = form.querySelector('[data-feedback]');
    const user = form.answer.value;
    const ok = normalize(user) === normalize(correct);

    if (ok && Number.isInteger(goodPage)) {
      window.location.href = `/puzzle/${puzzleId}/${goodPage}`;
      return false;
    }
    if (!ok && Number.isInteger(badPage)) {
      window.location.href = `/puzzle/${puzzleId}/${badPage}`;
      return false;
    }

    feedback.textContent = ok ? '✅ Klopt!' : '❌ Niet goed, probeer opnieuw.';
    feedback.style.color = ok ? '#059669' : '#dc2626';
    return false;
  }

  // ===== Kaart initialisatie (alleen als #map bestaat) =====
  // ===== Kaart initialisatie (alleen als #map bestaat) =====
  (function initMapIfPresent(){
    const mapEl = document.getElementById('map');
    if (!mapEl || typeof L === 'undefined') return;

    // Haal de doellocatie op vanuit de EJS / database
    const targetLat = <%= page.targetLat !== null && page.targetLat !== undefined ? page.targetLat : 'null' %>;
    const targetLng = <%= page.targetLng !== null && page.targetLng !== undefined ? page.targetLng : 'null' %>;
    const targetRadius = <%= page.targetRadius !== null && page.targetRadius !== undefined ? page.targetRadius : 50 %>;
    const hasNextPage = <%= hasNext ? 'true' : 'false' %>;
    const nextUrl = "/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>";

    let isRedirecting = false; // Voorkomt dat de pagina oneindig blijft herladen als je in het gebied staat

    // Init map – fallback NL
    const map = L.map('map', { zoomControl: true }).setView([52.1326, 5.2913], 7);

    // Gebruik de OpenStreetMap tiles (sneller en minder vaak geblokkeerd dan CARTO)
    const tiles = L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
    }).addTo(map);

    // Mobile rendering fixes
    function fixSize(){ try { map.invalidateSize(false); } catch(e){} }
    fixSize();
    requestAnimationFrame(fixSize);
    window.addEventListener('resize', fixSize, { passive:true });

    // === Optioneel: Teken het doelgebied op de kaart ===
    // Als je wilt dat spelers zien wáár ze naartoe moeten lopen, haal dan de '//' weg bij de volgende 3 regels:
    // if (targetLat !== null && targetLng !== null) {
    //   L.circle([targetLat, targetLng], { radius: targetRadius, color: '#ef4444', fillColor: '#ef4444', fillOpacity: 0.2 }).addTo(map);
    // }

    let userMarker = null;
    let accuracyCircle = null;

    function createUserIcon(){
      const container = document.createElement('div');
      container.style.position = 'relative';
      const dot = document.createElement('div');
      dot.className = 'user-dot pulse';
      container.appendChild(dot);
      return L.divIcon({ className: '', html: container, iconSize: [20,20], iconAnchor: [10,10] });
    }

    function onLocationFound(e){
      const latlng   = e.latlng;
      const accuracy = e.accuracy || 0;

      // Update de blauwe stip van de speler
      if (!userMarker) {
        userMarker = L.marker(latlng, { icon: createUserIcon(), zIndexOffset: 1000 }).addTo(map);
        if (map.getZoom() < 16) map.setView(latlng, 16);
      } else {
        userMarker.setLatLng(latlng);
      }

      if (!accuracyCircle) {
        accuracyCircle = L.circle(latlng, { radius: accuracy, color:'#1a73e8', weight: 1, fillColor:'#1a73e8', fillOpacity: 0.08 }).addTo(map);
      } else {
        accuracyCircle.setLatLng(latlng).setRadius(accuracy);
      }

      // --- 🚀 NIEUW: Check of de speler in het doelgebied is ---
      if (targetLat !== null && targetLng !== null && hasNextPage && !isRedirecting) {
        // Bereken de afstand in meters
        const distance = latlng.distanceTo([targetLat, targetLng]);
        
        console.log(`Je bent ${Math.round(distance)} meter verwijderd van het doel.`);

        // Zit de speler binnen de ingestelde radius?
        if (distance <= targetRadius) {
          isRedirecting = true; 
          
          // Leuke visuele overgang: laat de kaart even vervagen voordat hij naar de volgende pagina springt
          mapEl.style.transition = 'opacity 0.8s ease';
          mapEl.style.opacity = '0.3';
          
          setTimeout(() => {
            window.location.href = nextUrl;
          }, 1000); // 1 seconde vertraging voor een soepele overgang
        }
      }
    }

    function onLocationError(e){
      console.warn('Geolocatie mislukte:', e.message);
    }

    if (navigator.geolocation) {
      map.locate({ setView:false, enableHighAccuracy:true, timeout:10000, watch:true })
         .on('locationfound', onLocationFound)
         .on('locationerror', onLocationError);
    }
  })();
</script>

</body>
</html>
