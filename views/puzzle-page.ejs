<%
  const hasNext  = !!puzzle.pages[pageIndex + 1];
  const showNext = (typeof page?.showNext === 'boolean') ? page.showNext : true;
  const isMap    = (typeof page?.isMap === 'boolean')    ? page.isMap    : false;
%>

<!-- Leaflet CSS (voor kaartpagina's kan dit ook in je layout) -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<div class="space-y-6">
  <h1 class="text-2xl font-bold"><%= puzzle.name %></h1>
  <h2 class="text-xl font-semibold"><%= page.title %></h2>

  <% if (isMap) { %>
    <div id="map" class="rounded-xl border shadow" style="height: 65vh;"></div>

    <% if (hasNext && showNext) { %>
      <div class="pt-4">
        <a href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>"
           class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg">
          Volgende pagina <span aria-hidden="true">➜</span>
        </a>
      </div>
    <% } %>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
      (function(){
        const map = L.map('map').setView([52.1326, 5.2913], 7);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; OpenStreetMap-bijdragers'
        }).addTo(map);

        function onLocationFound(e) {
          const radius = e.accuracy;
          L.marker(e.latlng).addTo(map)
            .bindPopup('Je bent hier 🎯')
            .openPopup();
          L.circle(e.latlng, { radius, color:'#2563eb', fillColor:'#93c5fd', fillOpacity:0.35 }).addTo(map);
          map.setView(e.latlng, 16);
        }
        function onLocationError(e) {
          console.warn('Geolocatie mislukt:', e.message);
          L.popup().setLatLng(map.getCenter()).setContent('Kon je locatie niet ophalen. Sta locatie-toegang toe en gebruik HTTPS.').openOn(map);
        }
        if (navigator.geolocation) {
          map.locate({ setView:false, enableHighAccuracy:true, timeout:10000 })
             .on('locationfound', onLocationFound)
             .on('locationerror', onLocationError);
        } else {
          onLocationError({ message: 'Geolocatie niet ondersteund' });
        }
      })();
    </script>
  <% } else { %>
    <div class="space-y-4">
      <% (page.modules || []).forEach((mod) => { %>

        <% if (mod.type === "text") { %>
          <div class="p-4 bg-white border rounded-xl shadow">
            <%- mod.data?.text || "" %>
          </div>
        <% } %>

        <% if (mod.type === "image") { %>
          <div class="p-4 bg-white rounded-xl shadow">
            <% if (mod.data?.url) { %>
              <img src="<%= mod.data.url %>" alt="Afbeelding" class="w-full rounded-lg border" loading="lazy" />
            <% } else { %>
              <div class="text-gray-500 text-sm">Geen afbeelding opgegeven.</div>
            <% } %>
          </div>
        <% } %>

        <% if (mod.type === "question") { %>
          <div class="p-4 bg-white border rounded-xl shadow space-y-3">
            <p class="font-semibold"><%= mod.data?.question || "Vraag" %></p>
            <form class="space-y-2"
                  onsubmit="return checkAnswerBranch(
                    this,
                    '<%= (mod.data?.answer ? String(mod.data.answer).replace(/\"/g,'&quot;') : '') %>',
                    <%= (Number.isInteger(mod.data?.goodPage) ? mod.data.goodPage : 'null') %>,
                    <%= (Number.isInteger(mod.data?.badPage)  ? mod.data.badPage  : 'null') %>,
                    '<%= puzzle._id %>'
                  )">
              <input type="text" name="answer" placeholder="Jouw antwoord" class="border p-2 rounded w-full" autocomplete="off">
              <div class="flex gap-2">
                <button class="bg-blue-600 text-white px-4 py-2 rounded-lg">Controleer</button>
              </div>
              <div class="text-sm" data-feedback></div>
            </form>
          </div>
        <% } %>

        <% if (mod.type === "location") { %>
          <div class="p-4 bg-white border rounded-xl shadow space-y-1">
            <p class="font-semibold">Locatie‑check</p>
            <p>Lat: <%= (mod.data?.lat ?? "?") %></p>
            <p>Lng: <%= (mod.data?.lng ?? "?") %></p>
            <p>Straal: <%= (mod.data?.radius ?? 50) %> meter</p>
          </div>
        <% } %>

      <% }) %>
    </div>

    <% if (hasNext && showNext) { %>
      <div class="pt-4">
        <a href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>"
           class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg">
          Volgende pagina <span aria-hidden="true">➜</span>
        </a>
      </div>
    <% } %>
  <% } %>
</div>

<script>
  function normalize(str){
    return String(str||'').trim().toLowerCase().normalize('NFKD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,' ');
  }
  function checkAnswerBranch(form, correct, goodPage, badPage, puzzleId){
    const feedback = form.querySelector('[data-feedback]');
    const ok = normalize(form.answer.value) === normalize(correct);
    if (ok && Number.isInteger(goodPage)) { window.location.href = `/puzzle/${puzzleId}/${goodPage}`; return false; }
    if (!ok && Number.isInteger(badPage)) { window.location.href = `/puzzle/${puzzleId}/${badPage}`; return false; }
    feedback.textContent = ok ? '✅ Klopt!' : '❌ Niet goed, probeer opnieuw.';
    feedback.style.color = ok ? '#059669' : '#dc2626';
    return false;
  }
</script>
