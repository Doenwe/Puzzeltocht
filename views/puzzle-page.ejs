<% if (isMap) { %>
  <!-- ====== KAARTPAGINA ====== -->

  <!-- 1) Leaflet CSS & JS (CORRECTE tags) -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4RINsHSkP7vS9qSWwWxDPWZ0pniS3pS3G06G6pQnY8="
    crossorigin=""
  />
  <style>
    /* Stabiele, mobiele-proof hoogtes */
    #map {
      height: 65vh;      /* hoofdhoogte */
      min-height: 380px; /* fallback voor kleine schermen / iOS vh bug */
      border-radius: 14px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 10px 24px rgba(0,0,0,.08);
      background: #eef2ff; /* nette achtergrond tot tiles laden */
    }
    .leaflet-container { background: #eef2ff; }

    /* Professionele user-dot */
    .user-dot {
      width: 14px; height: 14px; border-radius: 50%;
      background: #1a73e8; border: 3px solid #fff;
      box-shadow: 0 0 0 2px rgba(26,115,232,0.25);
    }
    .user-dot.pulse { position: relative; }
    .user-dot.pulse::after {
      content: ""; position: absolute; left: 50%; top: 50%;
      width: 14px; height: 14px; transform: translate(-50%,-50%);
      border-radius: 50%; background: rgba(26,115,232,0.3);
      animation: userDotPulse 2.2s ease-out infinite;
    }
    @keyframes userDotPulse {
      0% { transform: translate(-50%,-50%) scale(1); opacity: .6; }
      70% { transform: translate(-50%,-50%) scale(2.6); opacity: 0; }
      100% { transform: translate(-50%,-50%) scale(2.6); opacity: 0; }
    }
    .heading-arrow {
      width: 0; height: 0;
      border-left: 6px solid transparent;
      border-right: 6px solid transparent;
      border-bottom: 10px solid #1a73e8;
      filter: drop-shadow(0 0 2px rgba(0,0,0,.3));
      transform-origin: 50% 80%;
      position: absolute; top: -14px; left: 50%;
      translate: -50% 0;
    }
  </style>

  <div id="map"></div>

  <% if (hasNext && showNext) { %>
    <div class="pt-4">
      <a class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg shadow hover:brightness-105"
         href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
        Volgende pagina <span aria-hidden="true">➜</span>
      </a>
    </div>
  <% } %>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    defer
    onload="window.__leafletLoaded = true"
  ></script>

  <script>
    (function(){
      // Wacht tot Leaflet script geladen is
      function ready(fn){ if(window.__leafletLoaded) fn(); else setTimeout(()=>ready(fn),30); }

      ready(function initMap(){
        const mapEl = document.getElementById('map');
        if(!mapEl) return;

        // 2) Init map met veilig fallback‑center (NL)
        const map = L.map('map', { zoomControl: true }).setView([52.1326, 5.2913], 7);

        // 3) Tiles (professioneel ogend, zonder API key): CARTO Voyager
        L.tileLayer(
          'https://{s}.basemaps.cartocdn.com/rastertiles/voyager{r}/{z}/{x}/{y}{r}.png',
          {
            maxZoom: 20,
            subdomains: 'abcd',
            attribution:
              '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> ' +
              'contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
          }
        ).addTo(map);

        // 4) Zorg dat Leaflet de echte grootte meet (mobiel fix)
        //   - direct na init
        //   - na een frame
        //   - op resize/visibilitychange
        map.invalidateSize();
        requestAnimationFrame(()=> map.invalidateSize());
        window.addEventListener('resize', ()=> map.invalidateSize(), { passive:true });
        document.addEventListener('visibilitychange', ()=> { if(!document.hidden) map.invalidateSize(); });

        // 5) Professionele user‑locatie
        let userMarker = null;
        let accuracyCircle = null;

        function createUserIcon(hasHeading){
          const container = document.createElement('div');
          container.style.position = 'relative';
          const dot = document.createElement('div');
          dot.className = 'user-dot pulse';
          container.appendChild(dot);
          if (hasHeading) {
            const arrow = document.createElement('div');
            arrow.className = 'heading-arrow';
            container.appendChild(arrow);
          }
          return L.divIcon({
            className: '',
            html: container,
            iconSize: [20,20],
            iconAnchor: [10,10]
          });
        }
        function setHeadingRotation(marker, heading){
          if (!marker || typeof heading !== 'number') return;
          const el = marker.getElement();
          if (!el) return;
          const arrow = el.querySelector('.heading-arrow');
          if (arrow) arrow.style.transform = `rotate(${heading}deg)`;
        }

        function onLocationFound(e){
          const latlng = e.latlng;
          const accuracy = e.accuracy || 0;
          const heading = (typeof e.heading === 'number') ? e.heading : null;

          if (!userMarker) {
            userMarker = L.marker(latlng, { icon: createUserIcon(!!heading), zIndexOffset: 1000 }).addTo(map);
          } else {
            userMarker.setLatLng(latlng);
          }
          if (heading != null) setHeadingRotation(userMarker, heading);

          if (!accuracyCircle) {
            accuracyCircle = L.circle(latlng, {
              radius: accuracy,
              color:'#1a73e8', weight: 1,
              fillColor:'#1a73e8', fillOpacity: 0.08
            }).addTo(map);
          } else {
            accuracyCircle.setLatLng(latlng).setRadius(accuracy);
          }

          // Zoom in op gebruiker (maar niet te agressief bij elke update)
          if (map.getZoom() < 15) map.setView(latlng, 15);
        }

        function onLocationError(e){
          console.warn('Geolocatie mislukte:', e.message);
          L.popup()
            .setLatLng(map.getCenter())
            .setContent('Kon je locatie niet ophalen. Sta locatie-toegang toe (HTTPS vereist) of probeer opnieuw.')
            .openOn(map);
        }

        // 6) Start geolocatie (HTTPS of localhost)
        if (navigator.geolocation) {
          map
            .locate({ setView:false, enableHighAccuracy:true, timeout:10000, watch:true })
            .on('locationfound', onLocationFound)
            .on('locationerror', onLocationError);
        } else {
          onLocationError({ message: 'Geolocatie wordt niet ondersteund.' });
        }

        // (Optioneel) DeviceOrientation voor heading (mobiel, toestemming nodig op iOS)
        if (window.DeviceOrientationEvent && typeof DeviceOrientationEvent.requestPermission !== 'function') {
          window.addEventListener('deviceorientation', (evt) => {
            if (!userMarker) return;
            const heading = (typeof evt.alpha === 'number') ? evt.alpha : null;
            setHeadingRotation(userMarker, heading);
          });
        }
      });
    })();
  </script>
<% } %>
