<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= puzzle.name %> — <%= page.title %></title>

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    :root {
      --bg:#f6f7fb;
      --card:#ffffff;
      --primary:#2563eb;
      --secondary:#475569;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e2e8f0;
      --ok:#16a34a;
      --bad:#dc2626;
    }

    * { box-sizing: border-box; }

    body{
      margin:0;
      background:var(--bg);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      color:var(--text);
    }

    .app {
      max-width:720px;
      margin:0 auto;
      padding:24px 16px 48px;
    }

    h1 {
      font-size:28px;
      margin:0 0 8px;
    }

    h2 {
      font-size:20px;
      margin:0 0 16px;
      color:var(--secondary);
    }

    /* Card */
    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:16px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 8px 24px rgba(0,0,0,.06);
    }

    /* Buttons */
    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:12px 18px;
      border-radius:10px;
      background:var(--primary);
      color:#fff;
      border:none;
      cursor:pointer;
      font-size:15px;
      font-weight:600;
      text-decoration:none;
      transition:filter .15s ease;
    }

    .btn:hover { filter:brightness(1.05); }

    .btn.secondary{
      background:var(--secondary);
      margin-top:24px;
    }

    input[type="text"],
    input[type="file"]{
      width:100%;
      padding:12px;
      border-radius:10px;
      border:1px solid var(--border);
      font-size:15px;
    }

    label{
      display:flex;
      gap:10px;
      align-items:center;
      margin:8px 0;
      cursor:pointer;
    }

    .feedback{
      margin-top:8px;
      font-weight:600;
    }

    .ok{ color:var(--ok); }
    .bad{ color:var(--bad); }

    /* Media */
    img{
      max-width:100%;
      border-radius:12px;
    }

    audio{
      width:100%;
      margin-top:4px;
    }

    /* Team header */
    .team-header{
      display:flex;
      gap:12px;
      align-items:center;
      margin-bottom:16px;
    }

    .team-photo{
      width:72px;
      height:72px;
      border-radius:50%;
      object-fit:cover;
      border:2px solid var(--border);
    }

    /* Map */
    #map{
      height:320px;
      border-radius:14px;
      overflow:hidden;
    }

    /* Multiple choice */
    .mc-options label{
      padding:10px 12px;
      border:1px solid var(--border);
      border-radius:10px;
      margin:6px 0;
      background:#f8fafc;
    }

    .mc-options input{
      margin-right:6px;
    }

    /* Image overlay */
    .overlay{
      position:fixed;
      inset:0;
      background:rgba(15,23,42,.8);
      display:none;
      align-items:center;
      justify-content:center;
      z-index:1000;
    }

    .overlay img{
      max-width:90%;
      max-height:90%;
      border-radius:16px;
    }
  </style>
</head>

<body>
<div class="app">

  <h1><%= puzzle.name %></h1>

  <% if (session?.teamName || session?.teamProfilePhoto) { %>
    <div class="team-header">
      <% if (session?.teamProfilePhoto) { %>
        <img src="<%= session.teamProfilePhoto %>" class="team-photo">
      <% } %>
      <% if (session?.teamName) { %>
        <strong><%= session.teamName %></strong>
      <% } %>
    </div>
  <% } %>

  <h2><%= page.title %></h2>

  <% if (page.playSoundOnStart && page.soundUrl) { %>
    <script>
      new Audio("<%= page.soundUrl %>").play().catch(()=>{});
    </script>
  <% } %>

  <% if (page.isMap) { %>
    <div class="card">
      <div id="map"></div>
      <div id="mapFeedback" class="feedback">Locatie bepalen…</div>
    </div>
  <% } %>

  <% (page.modules || []).forEach((mod, qIndex) => { %>

    <% if (mod.type === "text") { %>
      <div class="card"><%- mod.data.text %></div>
    <% } %>

    <% if (mod.type === "image") { %>
      <div class="card">
        <img src="<%= mod.data.url %>" onclick="openImage(this.src)">
      </div>
    <% } %>

    <% if (mod.type === "audio") { %>
      <div class="card">
        <audio controls src="<%= mod.data.url %>"></audio>
      </div>
    <% } %>

    <% if (mod.type === "team-name") { %>
      <div class="card">
        <strong>Teamnaam</strong>
        <input
          type="text"
          placeholder="Jullie teamnaam"
          value="<%= session?.teamName || '' %>"
          onblur="saveTeamName(this.value)">
        <div id="teamname-feedback" class="feedback"></div>
      </div>
    <% } %>

    <% if (mod.type === "question") { %>
      <div class="card">
        <strong><%= mod.data.question %></strong>

        <% if (mod.data.questionType === "mc") { %>
          <div class="mc-options"
               data-mc
               data-options='<%- JSON.stringify(mod.data.options || []) %>'
               data-good="<%= mod.data.goodPage ?? '' %>"
               data-bad="<%= mod.data.badPage ?? '' %>"
               data-puzzle="<%= puzzle._id %>">
            <% mod.data.options.forEach((o,i)=>{ %>
              <label>
                <input type="radio" name="mc-<%= qIndex %>" value="<%= i %>">
                <%= o.text %>
              </label>
            <% }) %>
            <button class="btn" onclick="handleMC(this)">Controleer</button>
            <div class="feedback"></div>
          </div>
        <% } else { %>
          <form onsubmit="return handleOpen(event,this)">
            <input name="answer" placeholder="Jouw antwoord">
            <button class="btn">Controleer</button>
            <div class="feedback"></div>

            <input type="hidden" name="correct" value="<%= mod.data.answer %>">
            <input type="hidden" name="good" value="<%= mod.data.goodPage ?? '' %>">
            <input type="hidden" name="bad" value="<%= mod.data.badPage ?? '' %>">
            <input type="hidden" name="puzzle" value="<%= puzzle._id %>">
          </form>
        <% } %>
      </div>
    <% } %>

  <% }) %>

  <% if (page.showNext && pageIndex + 1 < puzzle.pages.length) { %>
    <a class="btn secondary"
       href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
       Volgende pagina →
    </a>
  <% } %>

</div>

<div class="overlay" id="imgOverlay" onclick="this.style.display='none'">
  <img id="overlayImg">
</div>

<script>
function openImage(src){
  overlayImg.src = src;
  imgOverlay.style.display = "flex";
}
</script>

<% if (page.isMap) { %>
<script>
const target = L.latLng(<%= page.targetLat %>, <%= page.targetLng %>);
const radius = <%= page.targetRadius %>;
const showTarget = <%= page.showTarget ? "true" : "false" %>;
const autoNext = <%= page.autoNext ? "true" : "false" %>;

const map = L.map("map").setView(target, 16);
L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

if (showTarget) {
  L.marker(target).addTo(map);
  L.circle(target, { radius, color:"green", fillOpacity:.15 }).addTo(map);
}

const fb = document.getElementById("mapFeedback");
const nextBtn = document.querySelector(".btn.secondary");

navigator.geolocation.watchPosition(p=>{
  const user = L.latLng(p.coords.latitude, p.coords.longitude);
  map.setView(user,17);
  L.marker(user).addTo(map);
  const d = map.distance(user, target);
  fb.textContent = d <= radius
    ? "✅ Doel bereikt!"
    : `Afstand: ${Math.round(d)} meter`;

  if(d <= radius && autoNext && nextBtn){
    setTimeout(()=>location.href = nextBtn.href,1000);
  }
});
</script>
<% } %>

</body>
</html>
