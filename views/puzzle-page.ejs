<h1 class="text-2xl font-bold mb-4"><%= puzzle.name %></h1>

<h2 class="text-xl font-semibold mb-2"><%= page.title %></h2>

<div class="space-y-4">

  <% (page.modules || []).forEach(mod => { %>

    <% if (mod.type === "text") { %>
      <div class="p-4 bg-white border rounded-xl shadow">
        <!-- Builder slaat HTML op: on-escaped renderen -->
        <%- mod.data?.text || "" %>
      </div>
    <% } %>

    <% if (mod.type === "image") { %>
      <div class="p-4 bg-white rounded-xl shadow">
        <% if (mod.data?.url) { %>
          <img
            src="<%= mod.data.url %>"
            alt="Afbeelding"
            class="w-full rounded-lg border"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
          />
          <div class="text-gray-500 text-sm" style="display:none;">Afbeelding kon niet geladen worden.</div>
        <% } else { %>
          <div class="text-gray-500 text-sm">Geen afbeelding opgegeven.</div>
        <% } %>
      </div>
    <% } %>

    <% if (mod.type === "question") { %>
      <div class="p-4 bg-white border rounded-xl shadow space-y-3">
        <p class="font-semibold"><%= mod.data?.question || "Vraag" %></p>
        <form class="space-y-2" onsubmit="return checkAnswer(this, '<%= (mod.data?.answer ? String(mod.data.answer).replace(/"/g,'&quot;') : '') %>')">
          <input type="text" name="answer" placeholder="Jouw antwoord" class="border p-2 rounded w-full" autocomplete="off">
          <button class="mt-1 bg-blue-600 text-white px-4 py-2 rounded-lg">Controleer</button>
          <div class="text-sm" data-feedback></div>
        </form>
      </div>
    <% } %>

    <% if (mod.type === "location") { %>
      <div class="p-4 bg-white border rounded-xl shadow space-y-1">
        <p class="font-semibold">Locatie‑check</p>
        <p>Lat: <%= (mod.data?.lat ?? "?") %></p>
        <p>Lng: <%= (mod.data?.lng ?? "?") %></p>
        <p>Straal: <%= (mod.data?.radius ?? 50) %> meter</p>
      </div>
    <% } %>

  <% }) %>

</div>

<!-- NEXT PAGE BUTTON -->
<% if (puzzle.pages[pageIndex+1]) { %>
  <a href="/puzzle/<%= puzzle._id %>/<%= pageIndex+1 %>"
     class="inline-block mt-6 bg-blue-600 text-white px-4 py-2 rounded-lg">
    Volgende pagina ➜
  </a>
<% } %>

<script>
  function normalize(str){
    return String(str||'').trim().toLowerCase().normalize('NFKD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,' ');
  }
  function checkAnswer(form, correct){
    const feedback = form.querySelector('[data-feedback]');
    const ok = normalize(form.answer.value) === normalize(correct);
    feedback.textContent = ok ? '✅ Klopt!' : '❌ Niet goed, probeer opnieuw.';
    feedback.style.color = ok ? '#059669' : '#dc2626';
    return false; // voorkom page reload
  }
</script>
