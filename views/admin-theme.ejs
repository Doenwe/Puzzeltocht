<section class="space-y-5">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Thema aanpassen</h1>
    <% if (saved) { %><span class="text-green-700 text-sm">Opgeslagen</span><% } %>
  </div>

  <form id="theme-form" method="POST" action="/admin-theme" class="space-y-4">
    <label class="block text-sm">
      <span class="block mb-1 font-medium">Primair</span>
      <input type="color" name="primaryColor" value="<%= (theme && theme.primaryColor) || '#2563eb' %>"
        class="w-full border rounded p-2" />
    </label>

    <label class="block text-sm">
      <span class="block mb-1 font-medium">Achtergrond</span>
      <input type="color" name="backgroundColor" value="<%= (theme && theme.backgroundColor) || '#ffffff' %>"
        class="w-full border rounded p-2" />
    </label>

    <label class="block text-sm">
      <span class="block mb-1 font-medium">Tekst</span>
      <input type="color" name="textColor" value="<%= (theme && theme.textColor) || '#111827' %>"
        class="w-full border rounded p-2" />
    </label>

    <label class="block text-sm">
      <span class="block mb-1 font-medium">Hoekradius (bijv. 0.75rem of 12px)</span>
      <input type="text" name="borderRadius" value="<%= (theme && theme.borderRadius) || '0.75rem' %>"
        class="w-full border rounded p-2" />
    </label>

    <label class="block text-sm">
      <span class="block mb-1 font-medium">Lettertype stack</span>
      <input type="text" name="fontFamily"
        value="<%= (theme && theme.fontFamily) || 'Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, Noto Sans, Apple Color Emoji, Segoe UI Emoji' %>"
        class="w-full border rounded p-2" />
      <span class="text-xs text-gray-600">Tip: gebruik een complete stack voor goede fallback.</span>
    </label>

    <div class="mt-2">
      <h2 class="font-semibold mb-2">Live voorbeeld</h2>
      <div class="p-4 border rounded" style="background: var(--bg); color: var(--text); border-radius: var(--radius);">
        <p class="mb-3">Zo ziet een knop eruit:</p>
        <button type="button" class="btn-primary px-4 py-2">Voorbeeldknop</button>
        <div class="mt-4">
          <input class="w-full border rounded p-3" placeholder="Voorbeeld invoerveld" />
        </div>
      </div>
    </div>

    <button class="btn-primary w-full p-3 mt-2">Opslaan</button>
  </form>
</section>
