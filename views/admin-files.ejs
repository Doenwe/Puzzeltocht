<section class="space-y-6">

  <h1 class="text-2xl font-bold">Bestanden</h1>
  <p class="text-sm text-gray-600">
    Overzicht van alle geüploade bestanden. Je kunt links kopiëren voor gebruik in puzzels.
  </p>

  <!-- ========= ROOT UPLOADS ========= -->
  <% if (rootFiles && rootFiles.length) { %>
    <div class="card p-4 border rounded space-y-3">
      <h2 class="font-semibold text-lg">📂 uploads/ (root)</h2>

      <ul class="space-y-2">
        <% rootFiles.forEach(file => { 
          const filePath = `/uploads/${file.name}`;
        %>
          <li class="flex items-center justify-between text-sm bg-gray-50 p-2 rounded">

            <div>
              📄 <strong><%= file.name %></strong>
              <span class="text-gray-500">
                (<%= Math.round(file.size / 1024) %> KB)
              </span>
            </div>

            <div class="space-x-3">
              <a
                href="<%= filePath %>"
                target="_blank"
                class="text-blue-600 underline"
              >
                Bekijk
              </a>

              <button
                class="text-gray-700 underline"
                onclick="copyToClipboard('<%= filePath %>')"
              >
                Kopieer link
              </button>

              <button
                class="text-red-600 underline"
                onclick="deleteFile('', '<%= file.name %>')"
              >
                Verwijder
              </button>
            </div>

          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <!-- ========= SUBFOLDERS ========= -->
  <% if (folders && folders.length) { %>
    <% folders.forEach(folder => { %>
      <div class="card p-4 border rounded space-y-3">

        <h2 class="font-semibold text-lg">
          📁 <%= folder.name %>
        </h2>

        <% if (!folder.files || folder.files.length === 0) { %>
          <p class="text-sm text-gray-500">
            Deze map is leeg.
          </p>
        <% } else { %>
          <ul class="space-y-2">
            <% folder.files.forEach(file => { 
              const filePath = `/uploads/${folder.name}/${file.name}`;
            %>
              <li class="flex items-center justify-between text-sm bg-gray-50 p-2 rounded">

                <div>
                  📄 <strong><%= file.name %></strong>
                  <span class="text-gray-500">
                    (<%= Math.round(file.size / 1024) %> KB)
                  </span>
                </div>

                <div class="space-x-3">
                  <a
                    href="<%= filePath %>"
                    target="_blank"
                    class="text-blue-600 underline"
                  >
                    Bekijk
                  </a>

                  <button
                    class="text-gray-700 underline"
                    onclick="copyToClipboard('<%= filePath %>')"
                  >
                    Kopieer link
                  </button>

                  <button
                    class="text-red-600 underline"
                    onclick="deleteFile('<%= folder.name %>', '<%= file.name %>')"
                  >
                    Verwijder
                  </button>
                </div>

              </li>
            <% }) %>
          </ul>
        <% } %>

      </div>
    <% }) %>
  <% } %>

  <% if (
    (!rootFiles || rootFiles.length === 0) &&
    (!folders || folders.length === 0)
  ) { %>
    <p class="text-gray-500">
      Er zijn nog geen bestanden geüpload.
    </p>
  <% } %>

</section>

<script>
/* ✅ LINK KOPIËREN */
async function copyToClipboard(text) {
  try {
    await navigator.clipboard.writeText(text);
    toast(`Link gekopieerd: ${text}`);
  } catch (err) {
    alert("Kopiëren mislukt");
    console.error(err);
  }
}

/* ✅ VERWIJDEREN */
async function deleteFile(folder, file) {
  if (!confirm(`Bestand "${file}" verwijderen?`)) return;

  try {
    const res = await fetch("/admin-files/delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ folder, file })
    });

    if (!res.ok) throw new Error();
    location.reload();
  }
  catch (err) {
    alert("Verwijderen mislukt");
    console.error(err);
  }
}

/* ✅ SIMPLE TOAST */
function toast(msg) {
  const t = document.createElement("div");
  t.textContent = msg;

  Object.assign(t.style, {
    position: "fixed",
    right: "20px",
    bottom: "20px",
    background: "#2563eb",
    color: "#fff",
    padding: "10px 14px",
    borderRadius: "12px",
    boxShadow: "0 8px 24px rgba(0,0,0,.2)",
    zIndex: 9999,
    fontSize: "14px"
  });

  document.body.appendChild(t);
  setTimeout(() => t.remove(), 1800);
}
</script>
