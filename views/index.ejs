<div class="fixed inset-0 z-0 bg-[linear-gradient(135deg,#667eea_0%,#764ba2_100%)]"></div>

<main class="relative z-10 w-full max-w-md mx-auto min-h-screen flex items-center justify-center px-4 py-8">
  <!-- Glassmorphism Card -->
  <section class="w-full bg-white/10 backdrop-blur-xl border border-white/20 rounded-[24px] shadow-[0_8px_32px_0_rgba(0,0,0,0.3)] overflow-hidden">
    <div class="p-8 space-y-8">
      <!-- Logo -->
      <div class="flex justify-center pt-2">
        <img
          src="https://puzzeltocht.doenwe.events/uploads/Doen%20we!.png"
          alt="Doen We! Events"
          class="h-14 w-auto drop-shadow-md"
          loading="eager"
        />
      </div>

      <!-- Titel + uitleg -->
      <div class="text-center space-y-3">
        <h1 class="text-3xl font-bold tracking-tight text-white drop-shadow-md">
          Voer je code in
        </h1>
        <p class="text-sm text-white/80 leading-relaxed font-medium">
          Deze code heb je ontvangen bij je bestelling
          of tijdens de puzzeltocht.
        </p>
      </div>

      <!-- Foutmelding -->
      <% if (error) { %>
        <div class="rounded-xl border border-red-400/50 bg-red-500/20 backdrop-blur-md px-4 py-3 text-sm text-white shadow-inner font-semibold text-center">
          <%= error %>
        </div>
      <% } %>

      <!-- Formulier -->
      <form action="/check-code" method="POST" class="space-y-5">

        <!-- Code -->
        <div>
          <label for="code" class="block text-sm font-semibold text-white/90 mb-2 drop-shadow-sm">
            Jouw toegangscode
          </label>
          <input
            id="code"
            name="code"
            type="text"
            required
            autocomplete="one-time-code"
            placeholder="Bijv: DW-1234"
            class="w-full rounded-xl border border-white/30 bg-white/10 p-4 text-white placeholder-white/50
                   focus:outline-none focus:border-white focus:bg-white/20
                   focus:ring-2 focus:ring-white/40 transition-all text-center text-lg font-bold tracking-wider"
          />
        </div>

        <!-- Primaire CTA -->
        <button
          type="submit"
          class="w-full rounded-xl bg-gradient-to-r from-blue-500 to-blue-600 p-4
                 font-bold text-white text-lg tracking-wide shadow-lg
                 hover:from-blue-400 hover:to-blue-500
                 hover:-translate-y-0.5
                 transition-all active:scale-[0.98]
                 focus:outline-none focus:ring-2 focus:ring-blue-400/50">
          Start Avontuur →
        </button>

        <!-- Divider -->
        <div class="relative py-4">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-white/20"></div>
          </div>
        </div>

        <!-- Secundaire actie -->
        <a
          href="https://www.universe.com/events/puzzeltocht-tickets-KXNLW2"
          target="_blank"
          rel="noopener noreferrer"
          class="group block w-full rounded-xl border border-white/20 bg-black/10 p-4
                 text-center text-sm font-medium text-white/90
                 hover:bg-white/10 hover:border-white/40 transition-all backdrop-blur-sm"
        >
          Nog geen code? Koop tickets
          <span class="inline-block ml-1 transform transition-transform group-hover:translate-x-1">
            →
          </span>
        </a>

      </form>

      <!-- Reassurance -->
      <div class="flex items-center justify-center gap-2 text-xs text-white/60 pt-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 11c1.657 0 3 .895 3 2v3H9v-3c0-1.105 1.343-2 3-2z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 8a5 5 0 00-10 0v3h10V8z" />
        </svg>
        <span>
          Je code wordt alleen gebruikt voor toegang.
        </span>
      </div>
    </div>
  </section>
</main>
