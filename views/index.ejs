<section class="space-y-5">
  <h1 class="text-2xl font-bold">Voer je code in</h1>
  
  <% if (error) { %>
    <p class="text-red-600"><%= error %></p>
  <% } %>

  <form action="/check-code" method="POST" class="space-y-3">
    <input
      type="text"
      name="code"
      placeholder="Code"
      class="w-full border rounded p-3"
      required
    />

    <button class="btn-primary w-full p-3">
      Verder
    </button>

    <!-- Nieuwe knop onder "Verder" -->
    <a
      href="https://www.universe.com/events/puzzeltocht-tickets-KXNLW2"
      target="_blank"
      rel="noopener noreferrer"
      class="block text-center border border-gray-300 rounded p-3 text-gray-700 hover:bg-gray-100"
    >
      Koop tickets voor de puzzeltocht
    </a>
  </form>

  <p class="text-sm text-gray-600">
    Tip: een <strong>admin-code</strong> stuurt je naar het inlogscherm.
  </p>
</section>
