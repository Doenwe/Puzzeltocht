<!-- Background overschrijft layout.ejs -->
<div class="fixed inset-0 z-[-1] bg-[linear-gradient(135deg,#667eea_0%,#764ba2_100%)]"></div>

<div class="max-w-2xl mx-auto py-8 relative z-10">
  
  <div class="text-center mb-10">
    <h1 class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-yellow-300 to-yellow-600 mb-2 drop-shadow-sm">
      Hall of Fame
    </h1>
    <p class="text-white/80 font-medium text-lg">De absolute toppers van deze puzzeltocht.</p>
  </div>

  <div class="space-y-4 px-4">
    <% if (scores && scores.length > 0) { %>
      <% scores.forEach((score) => { %>
        <% 
           let bgClass = "bg-white/10";
           let borderClass = "border-white/20";
           let rankColor = "text-white/80";
           
           if (score.realRank === 1) { bgClass = "bg-yellow-400/20"; borderClass = "border-yellow-400/40"; rankColor = "text-yellow-400"; }
           else if (score.realRank === 2) { bgClass = "bg-gray-300/20"; borderClass = "border-gray-300/40"; rankColor = "text-gray-300"; }
           else if (score.realRank === 3) { bgClass = "bg-orange-400/20"; borderClass = "border-orange-400/40"; rankColor = "text-orange-400"; }
           
           if (score.isOwn) { borderClass = "border-blue-400"; bgClass = "bg-blue-500/20"; }
        %>

        <div class="flex justify-between items-center p-5 rounded-2xl border <%= borderClass %> <%= bgClass %> backdrop-blur-md shadow-[0_8px_32px_0_rgba(0,0,0,0.2)] transition-all hover:scale-[1.02]">
          
          <div class="flex items-center gap-4">
            <strong class="text-3xl <%= rankColor %> w-10 text-center font-black drop-shadow-md">
              <%= score.realRank === 1 ? '🥇' : (score.realRank === 2 ? '🥈' : (score.realRank === 3 ? '🥉' : '#' + score.realRank)) %>
            </strong>
            <span class="text-xl font-bold text-white tracking-wide">
              <%= score.teamName %> 
              <% if(score.isOwn) { %><span class="text-blue-300 text-sm ml-2 uppercase tracking-widest">(Jij)</span><% } %>
            </span>
          </div>
          
          <div class="text-right">
            <strong class="text-yellow-400 text-2xl font-black drop-shadow-md"><%= score.totalScore %> pt</strong>
            <div class="text-sm text-white/60 font-medium">Tijd: <%= Math.floor(score.totalTimeSec / 60) %> min</div>
          </div>
          
        </div>
      <% }) %>
    <% } else { %>
      <div class="text-center p-10 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl">
        <p class="text-white/70 italic text-lg">Nog geen teams hebben deze puzzeltocht afgerond. Worden jullie de eersten?</p>
      </div>
    <% } %>
  </div>
  
  <div class="mt-10 text-center">
    <a href="/" class="inline-block px-8 py-3 bg-white/10 hover:bg-white/20 border border-white/30 rounded-xl text-white font-semibold transition-all backdrop-blur-md hover:-translate-y-1">
      ← Terug naar start
    </a>
  </div>
</div>

<style>
  /* Navigatie (uit layout.ejs) overschrijven voor deze pagina */
  header.sticky { background: rgba(255,255,255,0.05) !important; backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255,255,255,0.1); }
  header.sticky a { color: white !important; }
</style>
