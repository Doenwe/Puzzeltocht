<style>
/* ------ PAGE LAYOUT ------ */
main {
  max-width: 100% !important;
  padding: 0 !important;
}

.builder {
  display: flex;
  height: calc(100vh - 80px);
  background: #f5f7fa;
  font-family: Inter, sans-serif;
}

/* ------ SIDEBAR ------ */
.sidebar {
  width: 260px;
  background: #ffffff;
  border-right: 1px solid #e5e7eb;
  padding: 25px;
  box-shadow: 4px 0 20px rgba(0,0,0,0.05);
}

.sidebar h2 {
  font-size: 18px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20px;
  letter-spacing: -0.5px;
}

.element-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 12px 15px;
  margin-bottom: 12px;
  background: #f9fafb;
  border-radius: 10px;
  border: 1px solid #e5e7eb;
  cursor: pointer;
  font-size: 15px;
  font-weight: 500;
  color: #374151;
  transition: all 0.2s ease;
}

.element-btn i {
  font-size: 18px;
  opacity: 0.8;
}

.element-btn:hover {
  background: #eef2ff;
  border-color: #6366f1;
  color: #111827;
}

/* ------ CANVAS ------ */
.canvas {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px;
}

/* ------ PHONE ------ */
.phone {
  width: 390px;
  height: 760px;
  border-radius: 35px;
  background: white;
  border: 4px solid #111;
  overflow-y: auto;
  box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  padding: 25px;
}

/* ------ BLOCKS ------ */
.block {
  padding: 20px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  margin-bottom: 15px;
  cursor: grab;
  position: relative;
  transition: all 0.2s ease;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.block:hover {
  transform: scale(1.01);
  box-shadow: 0 6px 14px rgba(0,0,0,0.08);
}

/* Block title */
.block h4 {
  margin: 0 0 8px;
  font-size: 16px;
  font-weight: 600;
  color: #111827;
}

/* Remove */
.remove-block {
  position: absolute;
  right: 10px;
  top: 10px;
  background: #ef4444;
  color: white;
  width: 22px;
  height: 22px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
  line-height: 20px;
  text-align: center;
  transition: 0.15s;
}
.remove-block:hover {
  background: #dc2626;
}

/* Drag state */
.drag-over {
  border: 2px dashed #6366f1 !important;
  background: #eef2ff;
}
</style>

<div class="builder">

  <!-- Sidebar -->
  <div class="sidebar">
    <h2>Elementen</h2>

    <button class="element-btn" data-type="text">Tekst</button>
    <button class="element-btn" data-type="image">Afbeelding</button>
    <button class="element-btn" data-type="question">Vraag</button>
    <button class="element-btn" data-type="location">Locatie</button>
  </div>

  <!-- Phone Canvas -->
  <div class="canvas">
    <div class="phone" id="phone"></div>
  </div>

</div>

<script>
//--------------------------------------
// Utility: maak HTML structuren per type
//--------------------------------------
function blockTemplate(type){
  switch(type){
    case "text":     return "<p>Nieuwe tekst</p>";
    case "image":    return "<p>📷 Afbeelding</p>";
    case "question": return "<p>❓ Vraag</p>";
    case "location": return "<p>📍 Locatie</p>";
  }
}

//--------------------------------------
// Block toevoegen
//--------------------------------------
document.querySelectorAll(".element-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    const type = btn.dataset.type;
    addBlock(type);
  });
});

function addBlock(type){
  const phone = document.getElementById("phone");

  const block = document.createElement("div");
  block.className = "block";
  block.draggable = true;
  block.innerHTML = `
    <button class="remove-block">×</button>
    ${blockTemplate(type)}
  `;

  block.addEventListener("dragstart", dragStart);
  block.addEventListener("dragover", dragOver);
  block.addEventListener("drop", drop);
  block.addEventListener("dragend", dragEnd);

  block.querySelector(".remove-block").addEventListener("click", () => block.remove());

  phone.appendChild(block);
}

//--------------------------------------
// Drag & Drop functionaliteit
//--------------------------------------
let draggedBlock = null;

function dragStart(e){
  draggedBlock = this;
  this.style.opacity = "0.4";
}

function dragEnd(){
  draggedBlock = null;
  this.style.opacity = "1";
  document.querySelectorAll(".block").forEach(b => b.classList.remove("drag-over"));
}

function dragOver(e){
  e.preventDefault();
  if(this !== draggedBlock){
    this.classList.add("drag-over");
  }
}

function drop(e){
  e.preventDefault();
  this.classList.remove("drag-over");

  if(this !== draggedBlock){
    const phone = document.getElementById("phone");
    const blocks = [...phone.querySelectorAll(".block")];
    const droppedIndex = blocks.indexOf(this);
    const draggedIndex = blocks.indexOf(draggedBlock);

    if(droppedIndex > draggedIndex){
      this.after(draggedBlock);
    } else {
      this.before(draggedBlock);
    }
  }
}
</script>
