<%
  const page = (puzzle && puzzle.pages && puzzle.pages.length)
    ? puzzle.pages[0]
    : { title: "Pagina 1", modules: [] };
%>

<style>
  :root{
    --primary:#6366f1;
    --bg:#f5f7fa;
    --text:#111827;
  }
  main{ max-width:100% !important; padding:0 !important; margin:0 !important; }

  /* Layout */
  .builder-wrap{
    display:flex;
    height:calc(100vh - 56px);
    background:var(--bg);
    font-family:Inter, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial;
    color:var(--text);
  }

  /* Sidebar */
  .sidebar{
    width:280px;
    background:white;
    border-right:1px solid #e5e7eb;
    padding:22px;
    display:flex;
    flex-direction:column;
    gap:20px;
  }
  .sidebar h2{ font-size:20px; font-weight:800; margin:0; }
  .element-btn{
    width:100%;
    display:flex;
    align-items:center;
    gap:10px;
    padding:12px;
    background:#f9fafb;
    border:1px solid #e5e7eb;
    border-radius:10px;
    cursor:pointer;
    font-weight:600;
    transition:.15s ease;
  }
  .element-btn:hover{
    background:#eef2ff;
    border-color:var(--primary);
  }
  .sidebar-actions{
    margin-top:auto;
    display:flex;
    gap:12px;
  }
  .btn{
    flex:1;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    font-weight:700;
    cursor:pointer;
  }
  .btn-primary{
    background:var(--primary);
    color:white;
    border:none;
  }

  /* Canvas / stage */
  .canvas{
    flex:1;
    display:flex;
    justify-content:center;
    align-items:flex-start;
    padding:30px;
  }
  .stage{
    display:flex;
    gap:25px;
  }

  /* Phone preview */
  .phone{
    width:380px;
    height:740px;
    background:white;
    border-radius:35px;
    border:4px solid #111;
    overflow-y:auto;
    box-shadow:0 20px 50px rgba(0,0,0,0.18);
    padding:22px;
  }
  .phone-header{
    position:sticky; top:0; background:white;
    padding-bottom:12px;
    border-bottom:1px dashed #ddd;
    margin-bottom:12px;
    z-index:10;
    display:flex;
    justify-content:space-between;
    gap:10px;
  }

  /* Block */
  .block{
    padding:18px;
    background:white;
    border:1px solid #e5e7eb;
    border-radius:14px;
    margin-bottom:14px;
    box-shadow:0 4px 10px rgba(0,0,0,0.05);
    cursor:grab;
    position:relative;
  }
  .block.dragging{ opacity:.4; }
  .block h4{
    margin:0 0 8px; font-weight:700; font-size:15px;
    display:flex; gap:6px; align-items:center;
  }
  .kind{
    background:#f3f4f6;
    border:1px solid #ddd;
    padding:2px 6px;
    border-radius:8px;
    font-size:11px;
  }
  .remove{
    position:absolute;
    top:10px;
    right:10px;
    background:#ef4444;
    color:white;
    width:24px;
    height:24px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:900;
  }
  .drag-over{
    border:2px dashed var(--primary) !important;
    background:#eef2ff;
  }

  /* Contenteditable styling */
  [contenteditable="true"]{
    padding:6px;
    border-radius:8px;
    transition:.15s ease;
    outline:2px dashed transparent;
  }
  [contenteditable="true"]:focus{
    background:#f0f4ff;
    outline-color:#aab4ff;
  }

  /* Form fields inside blocks */
  .block input, .block textarea{
    width:100%;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    margin-bottom:8px;
    font-size:14px;
  }
  .form-row{ display:flex; gap:10px; }

  /* Settings panel */
  .panel{
    width:300px;
    background:white;
    border-radius:16px;
    border:1px solid #e5e7eb;
    padding:20px;
    box-shadow:0 8px 28px rgba(0,0,0,0.1);
    position:sticky;
    top:30px;
    height:fit-content;
  }
  .panel h3{ margin:0 0 8px; }
  .panel label{ font-size:13px; margin-top:10px; display:block; }
  .panel input, .panel textarea{
    width:100%; padding:10px;
    margin-top:4px;
    border-radius:8px;
    border:1px solid #ccc;
  }
</style>

<div class="builder-wrap">

  <!-- Sidebar -->
  <div class="sidebar">
    <h2>Builder</h2>

    <div>
      <button class="element-btn" type="button" data-type="text">📝 Tekst</button>
      <button class="element-btn" type="button" data-type="image">🖼️ Afbeelding</button>
      <button class="element-btn" type="button" data-type="question">❓ Vraag</button>
      <button class="element-btn" type="button" data-type="location">📍 Locatie</button>
    </div>

    <div class="sidebar-actions">
      <button class="btn" type="button" id="btn-reset">Reset</button>
      <button class="btn btn-primary" type="button" id="btn-save">Opslaan</button>
    </div>
  </div>

  <!-- Canvas -->
  <div class="canvas">
    <div class="stage">

      <!-- PHONE PREVIEW -->
      <div class="phone" id="phone" data-id="<%= puzzle._id %>">

        <div class="phone-header">
          <strong><%= puzzle.name %></strong>
          <span><%= page.title %></span>
        </div>

        <% (page.modules || []).forEach(m => { %>
          <div class="block" draggable="true" data-type="<%= m.type %>">
            <button class="remove" type="button">×</button>

            <h4>
              <span><%= m.type?.[0]?.toUpperCase() + m.type?.slice(1) %></span>
              <span class="kind"><%= m.type %></span>
            </h4>

            <div class="content">
              <% if(m.type === "text"){ %>
                <div contenteditable="true" data-field="text"><%- m.data?.text || "Nieuwe tekst" %></div>

              <% } else if(m.type === "image"){ %>
                <input type="url" data-field="url" value="<%= m.data?.url || '' %>">
                <% if(m.data?.url){ %>
                  <img class="preview" src="<%= m.data.url %>" style="width:100%;border-radius:10px;" alt="preview">
                <% } else { %>
                  <div class="helper">Voeg een afbeelding URL toe.</div>
                <% } %>

              <% } else if(m.type === "question"){ %>
                <label>Vraag:</label>
                <input type="text" data-field="question" value="<%= m.data?.question || '' %>">
                <label>Antwoord:</label>
                <input type="text" data-field="answer" value="<%= m.data?.answer || '' %>">

              <% } else if(m.type === "location"){ %>
                <div class="form-row">
                  <input type="number" step="0.000001" placeholder="Lat" data-field="lat" value="<%= m.data?.lat ?? '' %>">
                  <input type="number" step="0.000001" placeholder="Lng" data-field="lng" value="<%= m.data?.lng ?? '' %>">
                </div>
                <input type="number" step="1" placeholder="radius" data-field="radius" value="<%= m.data?.radius ?? 50 %>">

              <% } else { %>
                <div class="helper">Onbekend type: <%= m.type %></div>
              <% } %>
            </div>
          </div>
        <% }) %>

      </div>

      <!-- SETTINGS PANEL -->
      <div class="panel">
        <h3>Instellingen</h3>
        <small id="panel-empty">Klik op een blok om te bewerken.</small>
        <div id="panel-fields" style="display:none;">
          <label>Type</label>
          <input id="panel-type" disabled>
          <div id="panel-dynamic"></div>
        </div>
      </div>

    </div>
  </div>

</div>

<script>
(function(){
  const phone = document.getElementById("phone");
  if (!phone) return;

  const qs  = (s, p=document)=>p.querySelector(s);
  const qsa = (s, p=document)=>Array.from(p.querySelectorAll(s));

  /* ---------- Create & Add block ---------- */
  function createBlock(type){
    const div = document.createElement("div");
    div.className="block";
    div.draggable=true;
    div.dataset.type=type;

    div.innerHTML = `
      <button class="remove" type="button">×</button>
      <h4>
        <span>${type[0].toUpperCase()+type.slice(1)}</span>
        <span class="kind">${type}</span>
      </h4>
      <div class="content"></div>
    `;

    const content = qs(".content", div);

    if(type==="text"){
      content.innerHTML = `<div contenteditable="true" data-field="text">Nieuwe tekst</div>`;
    }
    if(type==="image"){
      content.innerHTML = `
        <input type="url" data-field="url" placeholder="Afbeeldings-URL">
        <div class="helper">Voeg een afbeelding URL toe.</div>
      `;
    }
    if(type==="question"){
      content.innerHTML = `
        <label>Vraag:</label>
        <input data-field="question">
        <label>Antwoord:</label>
        <input data-field="answer">
      `;
    }
    if(type==="location"){
      content.innerHTML = `
        <div class="form-row">
          <input type="number" step="0.000001" placeholder="Lat" data-field="lat">
          <input type="number" step="0.000001" placeholder="Lng" data-field="lng">
        </div>
        <input type="number" step="1" placeholder="Radius" data-field="radius" value="50">
      `;
    }

    wireBlock(div);
    return div;
  }

  function addBlock(type){
    const block = createBlock(type);
    phone.appendChild(block);
    setSelected(block);
  }

  // --- Hook de sidebar & header knoppen ---
  qsa('.element-btn').forEach(btn => {
    btn.setAttribute('type','button');
    btn.addEventListener('click', () => addBlock(btn.dataset.type));
  });
  // (optioneel) als je headershortcut knoppen toevoegt
  document.getElementById('btn-add-text')?.addEventListener('click', () => addBlock('text'));
  document.getElementById('btn-add-image')?.addEventListener('click', () => addBlock('image'));

  /* ---------- Drag & Drop (container-based) ---------- */
  let dragged=null;

  function getAfterEl(container, y){
    const blocks=qsa(".block:not(.dragging)",container);
    return blocks.reduce((closest, child)=>{
      const box=child.getBoundingClientRect();
      const offset=y-(box.top+box.height/2);
      if(offset<0 && offset>closest.offset){
        return {offset,element:child};
      }
      return closest;
    }, {offset:-Infinity,element:null}).element;
  }

  phone.addEventListener("dragover", e=>{
    if(!dragged) return;
    e.preventDefault();
    const after=getAfterEl(phone, e.clientY);
    if(after==null) phone.appendChild(dragged);
    else phone.insertBefore(dragged, after);
  });

  function wireBlock(block){
    block.addEventListener("dragstart", e=>{
      dragged=block;
      block.classList.add("dragging");
      if(e.dataTransfer){
        e.dataTransfer.setData("text/plain","");
        e.dataTransfer.effectAllowed="move";
      }
    });
    block.addEventListener("dragend", ()=>{
      block.classList.remove("dragging");
      dragged=null;
    });

    // live image preview
    block.addEventListener("input", e=>{
      if(e.target.matches('input[data-field="url"]')){
        const url=e.target.value.trim();
        const old=qs("img.preview", block);
        const helper=qs(".helper",block);

        if(url){
          if(old){ old.src=url; }
          else {
            const img=document.createElement("img");
            img.className="preview";
            img.src=url;
            img.style.width="100%";
            img.style.borderRadius="10px";
            if(helper) helper.replaceWith(img);
            else qs(".content",block).appendChild(img);
          }
        } else if(old){
          const h=document.createElement("div");
          h.className="helper";
          h.textContent="Voeg een afbeelding URL toe.";
          old.replaceWith(h);
        }
      }
    });

    block.addEventListener("click",()=> setSelected(block));
  }

  // Wire bestaande blocks
  qsa("#phone .block").forEach(wireBlock);

  /* ---------- Delete via event delegation ---------- */
  phone.addEventListener("click", e=>{
    if(e.target.classList.contains("remove")){
      const bl=e.target.closest(".block");
      if(bl){
        if(selected===bl) clearPanel();
        bl.remove();
      }
    }
  });

  /* ---------- Settings panel ---------- */
  let selected=null;
  const pEmpty=qs("#panel-empty");
  const pFields=qs("#panel-fields");
  const pType=qs("#panel-type");
  const pDyn=qs("#panel-dynamic");

  function setSelected(block){
    selected=block;
    pEmpty.style.display="none";
    pFields.style.display="block";
    pDyn.innerHTML="";

    const type=block.dataset.type;
    pType.value=type;

    if(type==="text"){
      const src=qs('[data-field="text"]',block);
      pDyn.innerHTML=`<label>Tekst</label><textarea id="p-text" rows="4"></textarea>`;
      const ta=qs("#p-text");
      ta.value=src?.innerHTML || "";
      ta.oninput=()=>{ if(src) src.innerHTML=ta.value; };
    }

    if(type==="image"){
      const src=qs('input[data-field="url"]',block);
      pDyn.innerHTML=`<label>Afbeeldings-URL</label><input id="p-url" type="url" placeholder="https://...">`;
      const inp=qs("#p-url");
      inp.value=src?.value || "";
      inp.oninput=()=>{
        if(src){
          src.value=inp.value;
          src.dispatchEvent(new Event("input"));
        }
      };
    }

    if(type==="question"){
      const q=qs('input[data-field="question"]',block);
      const a=qs('input[data-field="answer"]',block);
      pDyn.innerHTML=`
        <label>Vraag</label><input id="p-q" type="text">
        <label>Antwoord</label><input id="p-a" type="text">
      `;
      qs("#p-q").value=q?.value || "";
      qs("#p-a").value=a?.value || "";
      qs("#p-q").oninput=()=>{ if(q) q.value=qs("#p-q").value; };
      qs("#p-a").oninput=()=>{ if(a) a.value=qs("#p-a").value; };
    }

    if(type==="location"){
      const lat=qs('input[data-field="lat"]',block);
      const lng=qs('input[data-field="lng"]',block);
      const r=qs('input[data-field="radius"]',block);
      pDyn.innerHTML=`
        <div class="form-row">
          <div>
            <label>Lat</label>
            <input id="p-lat" type="number" step="0.000001">
          </div>
          <div>
            <label>Lng</label>
            <input id="p-lng" type="number" step="0.000001">
          </div>
        </div>
        <label>Radius</label>
        <input id="p-r" type="number" step="1">
      `;
      qs("#p-lat").value=lat?.value || "";
      qs("#p-lng").value=lng?.value || "";
      qs("#p-r").value=r?.value || 50;
      qs("#p-lat").oninput=()=>{ if(lat) lat.value=qs("#p-lat").value; };
      qs("#p-lng").oninput=()=>{ if(lng) lng.value=qs("#p-lng").value; };
      qs("#p-r").oninput=()=>{ if(r) r.value=qs("#p-r").value; };
    }
  }

  function clearPanel(){
    selected=null;
    pEmpty.style.display="block";
    pFields.style.display="none";
    pDyn.innerHTML="";
  }

  /* ---------- Collect & Save ---------- */
  function collect(){
    return qsa("#phone .block").map(b=>{
      const type=b.dataset.type;
      const data={};
      if(type==="text"){
        data.text = qs('[data-field="text"]',b)?.innerHTML || "";
      }
      if(type==="image"){
        data.url = qs('input[data-field="url"]',b)?.value?.trim() || "";
      }
      if(type==="question"){
        data.question = qs('input[data-field="question"]',b)?.value || "";
        data.answer   = qs('input[data-field="answer"]',b)?.value || "";
      }
      if(type==="location"){
        const lat = qs('input[data-field="lat"]',b)?.value;
        const lng = qs('input[data-field="lng"]',b)?.value;
        const rad = qs('input[data-field="radius"]',b)?.value;
        data.lat    = lat !== "" ? Number(lat) : null;
        data.lng    = lng !== "" ? Number(lng) : null;
        data.radius = rad !== "" ? Number(rad) : 50;
      }
      return { type, data };
    });
  }

  async function save(){
    const id = phone.dataset.id;
    const payload = { pageIndex:0, modules:collect() };

    const res = await fetch(`/admin-builder/${id}/save`,{
      method:"POST",
      headers:{ "Content-Type":"application/json"},
      body:JSON.stringify(payload)
    });

    if(res.ok) toast("Opgeslagen ✅");
    else toast("Opslaan mislukt ❌", true);
  }

  function resetPage(){ location.reload(); }

  document.getElementById("btn-save").addEventListener('click', save);
  document.getElementById("btn-reset").addEventListener('click', resetPage);

  /* ---------- Tiny toast ---------- */
  function toast(msg, error=false){
    const t=document.createElement('div');
    t.textContent=msg;
    t.style.position='fixed';
    t.style.right='20px';
    t.style.bottom='20px';
    t.style.background= error ? '#ef4444' : 'var(--primary)';
    t.style.color='#fff';
    t.style.padding='10px 14px';
    t.style.borderRadius='12px';
    t.style.boxShadow='0 8px 24px rgba(0,0,0,.2)';
    t.style.zIndex='9999';
    document.body.appendChild(t);
    setTimeout(()=> t.remove(), 2000);
  }
})();
</script>
