<style>
  <% 
    const theme = puzzle.theme?.preset || 'standard'; 
    const primary = puzzle.theme?.primaryColor || '#0066cc';
  %>

  :root { --primary: <%= primary %>; }

  /* 1. ABSOLUTE BASIS FIXES VOOR INTERACTIE */
  body { padding: 24px 16px; margin: 0; min-height: 100vh; overflow-x: hidden; position: relative; }
  * { box-sizing: border-box; }
  
  /* De Kaart Basis: Bevat de elementen maar blokkeert niets */
  .card { padding: 24px; margin-bottom: 24px; position: relative; transition: all 0.3s ease; width: 100%; z-index: 10; word-wrap: break-word; }
  
  /* CRUCIAAL: Dwing alle functionele elementen naar voren en maak ze klikbaar */
  h1, h2, h3, p, .card > div { position: relative; z-index: 20; }
  .btn, input, select, textarea, .chat-input-container, button { position: relative !important; z-index: 100 !important; pointer-events: auto !important; }
  
  /* Zorg dat knoppen niet uitbreken op kleine schermen */
  .btn { display: block; width: 100%; text-align: center; padding: 16px; cursor: pointer; font-size: 15px; border: none; min-height: 50px; height: auto; white-space: normal; line-height: 1.4; margin-bottom: 12px; }

  /* Zorg dat ALLE decoratieve overlays (ijspegels, perkament-randen, etc) NOOIT muiskliks stelen */
  .card::before, .card::after, body::before, body::after { pointer-events: none !important; z-index: 5 !important; }

  /* 2. DE CSS THEMA ENGINE */

  /* --- THEMA: IJSTIJD (IJs & Sneeuw) --- */
  <% if (theme === 'iceage') { %>
    body { background: #f0f9ff; color: #0c4a6e; }
    
    /* Bewegende sneeuw */
    body::before { content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background-image: radial-gradient(#bae6fd 2px, transparent 2px); background-size: 30px 30px; opacity: 0.7; animation: snowAnim 15s linear infinite; }
    @keyframes snowAnim { 0% { background-position: 0px 0px; } 100% { background-position: 0px 600px; } }

    .card { background: rgba(255, 255, 255, 0.7); border: 2px solid #e0f2fe; border-radius: 16px; backdrop-filter: blur(10px); box-shadow: 0 10px 30px rgba(186, 230, 253, 0.6); }
    
    /* IJspegels met Base64 SVG (Laden direct in) */
    .card::after { content: ""; position: absolute; top: -2px; left: 0; width: 100%; height: 25px; background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 20" preserveAspectRatio="none"><path d="M0,0 L5,20 L10,0 L18,12 L28,0 L40,18 L55,0 L70,10 L80,0 L92,15 L100,0 Z" fill="%23e0f2fe"/></svg>'); }

    .btn { background: #38bdf8; border-radius: 100px; border-bottom: 4px solid #0284c7; color: white; font-weight: 800; text-shadow: 0 1px 2px rgba(0,0,0,0.2); }
    .btn:active { transform: translateY(4px); border-bottom: 0px; margin-bottom: 16px; }

  /* --- THEMA: MIDDELEEUWEN (Perkament & Waszegels) --- */
  <% } else if (theme === 'medieval') { %>
    body { background: #d7c4a3 url('https://www.transparenttextures.com/patterns/papyros.png'); font-family: 'Georgia', serif; color: #3e2723; }
    
    /* Rafelige randen simulatie met inset shadow en border */
    .card { background: #f4e4bc; border: 1px solid #bcaaa4; box-shadow: 6px 6px 15px rgba(0,0,0,0.2); border-radius: 2px; }
    .card::before { content: ""; position: absolute; top:0; left:0; width:100%; height:100%; box-shadow: inset 0 0 50px rgba(139,69,19,0.15); }
    
    /* Waszegel Knoppen */
    .btn { background: #5d4037; color: #fff; border-radius: 2px; border: 2px solid #3e2723; text-transform: uppercase; letter-spacing: 1.5px; box-shadow: 3px 3px 0px #3e2723; font-weight: 900; }
    .btn:active { transform: translate(3px, 3px); box-shadow: 0px 0px 0px #3e2723; margin-bottom: 12px; }

  /* --- THEMA: TOEKOMST (Cyberpunk Hologram) --- */
  <% } else if (theme === 'future') { %>
    body { background: #020617; color: #38bdf8; font-family: 'Courier New', monospace; background-image: linear-gradient(0deg, transparent 24%, rgba(56, 189, 248, .05) 25%, rgba(56, 189, 248, .05) 26%, transparent 27%, transparent 74%, rgba(56, 189, 248, .05) 75%, rgba(56, 189, 248, .05) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(56, 189, 248, .05) 25%, rgba(56, 189, 248, .05) 26%, transparent 27%, transparent 74%, rgba(56, 189, 248, .05) 75%, rgba(56, 189, 248, .05) 76%, transparent 77%, transparent); background-size: 50px 50px; }
    
    .card { background: rgba(15, 23, 42, 0.85); border: 1px solid var(--primary); box-shadow: 0 0 20px rgba(var(--primary), 0.2); backdrop-filter: blur(8px); clip-path: polygon(0 0, 96% 0, 100% 15px, 100% 100%, 4% 100%, 0 calc(100% - 15px)); border-radius: 0; }
    
    .btn { background: transparent; border: 1px solid var(--primary); color: var(--primary); text-transform: uppercase; font-weight: 900; box-shadow: inset 0 0 15px rgba(56, 189, 248, 0.1); letter-spacing: 2px; transition: 0.1s; }
    .btn:hover, .btn:active { background: var(--primary); color: #020617; box-shadow: 0 0 25px var(--primary); }

  /* --- THEMA: STANDAARD (Modern Apple Stijl) --- */
  <% } else { %>
    body { background: #f5f5f7; color: #1d1d1f; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif; }
    .card { background: #ffffff; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 10px 20px rgba(0,0,0,0.03); }
    .btn { background: var(--primary); border-radius: 12px; color: white; font-weight: 600; }
  <% } %>
</style>
