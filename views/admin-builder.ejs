```ejs
<% layout('layout') %>

<style>
/* Zorg dat admin pagina full width is */
main{
  max-width:100% !important;
  padding:0 !important;
}

/* Builder layout */
.builder{
  display:flex;
  height:calc(100vh - 80px);
  background:#5fd0d0;
}

/* Sidebar */
.sidebar{
  width:260px;
  background:white;
  border-right:1px solid #ddd;
  padding:20px;
}

.sidebar h2{
  font-size:18px;
  font-weight:600;
  margin-bottom:15px;
}

.element-btn{
  display:block;
  width:100%;
  padding:10px;
  margin-bottom:10px;
  background:#f3f3f3;
  border-radius:6px;
  border:none;
  cursor:pointer;
}

.element-btn:hover{
  background:#e6e6e6;
}

/* Canvas area */
.canvas{
  flex:1;
  display:flex;
  justify-content:center;
  align-items:center;
}

/* Phone preview */
.phone{
  width:375px;
  height:700px;
  background:white;
  border-radius:30px;
  border:3px solid #333;
  overflow-y:auto;
  box-shadow:0 10px 40px rgba(0,0,0,0.2);
  padding:20px;
}

.block{
  padding:10px;
  margin-bottom:10px;
  border-radius:6px;
  border:1px dashed #ccc;
}
</style>

<div class="builder">

  <!-- Sidebar -->
  <div class="sidebar">
    <h2>Elementen</h2>

    <button class="element-btn" onclick="addBlock('text')">
      Tekst
    </button>

    <button class="element-btn" onclick="addBlock('image')">
      Afbeelding
    </button>

    <button class="element-btn" onclick="addBlock('question')">
      Vraag
    </button>

    <button class="element-btn" onclick="addBlock('location')">
      Locatie
    </button>

  </div>


  <!-- Preview Canvas -->
  <div class="canvas">

    <div class="phone" id="phone">

      <% if(puzzle && puzzle.blocks){ %>
        <% puzzle.blocks.forEach(block => { %>

          <div class="block">
            <%= block.type %>
          </div>

        <% }) %>
      <% } %>

    </div>

  </div>

</div>


<script>
function addBlock(type){

  const phone = document.getElementById("phone")

  const block = document.createElement("div")
  block.className = "block"

  if(type === "text"){
    block.innerHTML = "<p>Nieuwe tekst</p>"
  }

  if(type === "image"){
    block.innerHTML = "<p>📷 Afbeelding</p>"
  }

  if(type === "question"){
    block.innerHTML = "<p>❓ Vraag</p>"
  }

  if(type === "location"){
    block.innerHTML = "<p>📍 Locatie</p>"
  }

  phone.appendChild(block)

}
</script>
```
