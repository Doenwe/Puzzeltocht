<style>

.builder{
display:flex;
height:90vh;
width:100%;
font-family:sans-serif;
}

/* LINKERKANT */

.pages{
width:260px;
border-right:1px solid #ddd;
padding:15px;
overflow:auto;
}

.page{
padding:8px;
border:1px solid #ccc;
margin-bottom:6px;
cursor:pointer;
border-radius:6px;
}

.page.active{
background:#eee;
}

/* TELEFOON */

.preview{
flex:1;
display:flex;
justify-content:center;
align-items:center;
}

.phone{
width:375px;
height:700px;
border:2px solid black;
border-radius:30px;
padding:15px;
overflow:auto;
background:white;
}

.block{
border:1px dashed #bbb;
padding:10px;
margin-bottom:10px;
cursor:move;
background:#fafafa;
position:relative;
}

.delete{
position:absolute;
right:5px;
top:5px;
cursor:pointer;
font-size:12px;
}

/* RECHTS */

.modules{
width:260px;
border-left:1px solid #ddd;
padding:15px;
overflow:auto;
}

.module{
padding:10px;
border:1px solid #ccc;
margin-bottom:10px;
cursor:grab;
background:#fafafa;
border-radius:6px;
}

button{
padding:8px;
margin-top:10px;
}

</style>



<h2><%= puzzle.name %></h2>

<div class="builder">

<!-- PAGINA'S -->

<div class="pages">

<h3>Pagina's</h3>

<div id="pageList"></div>

<button onclick="addPage()">+ Pagina</button>

<button onclick="save()">Opslaan</button>

</div>


<!-- TELEFOON -->

<div class="preview">

<div id="phone" class="phone"></div>

</div>


<!-- MODULES -->

<div class="modules">

<h3>Modules</h3>

<div class="module" draggable="true" data-type="text">Tekst</div>
<div class="module" draggable="true" data-type="image">Afbeelding</div>
<div class="module" draggable="true" data-type="button">Knop</div>
<div class="module" draggable="true" data-type="answer">Antwoord</div>

</div>

</div>



<script>

let pages=<%- JSON.stringify(puzzle.pages || []) %>

let currentPage=0

const phone=document.getElementById("phone")
const pageList=document.getElementById("pageList")


function renderPages(){

pageList.innerHTML=""

pages.forEach((p,i)=>{

const div=document.createElement("div")
div.className="page"+(i===currentPage?" active":"")

div.innerText="Pagina "+(i+1)

div.onclick=()=>{
currentPage=i
renderPages()
renderPhone()
}

pageList.appendChild(div)

})

}


function renderPhone(){

phone.innerHTML=""

const blocks=pages[currentPage].blocks || []

blocks.forEach((b,i)=>{

const el=document.createElement("div")
el.className="block"
el.draggable=true

const del=document.createElement("div")
del.className="delete"
del.innerText="✕"

del.onclick=()=>{
blocks.splice(i,1)
renderPhone()
}

el.appendChild(del)

if(b.type==="text") el.innerHTML+="<p>Tekst</p>"
if(b.type==="image") el.innerHTML+="<img src='https://placehold.co/300x150'>"
if(b.type==="button") el.innerHTML+="<button>Knop</button>"
if(b.type==="answer") el.innerHTML+="<input placeholder='Antwoord'>"

phone.appendChild(el)

})

}


function addPage(){

pages.push({blocks:[]})

renderPages()

}


document.querySelectorAll(".module").forEach(m=>{

m.addEventListener("dragstart",e=>{
e.dataTransfer.setData("type",m.dataset.type)
})

})


phone.addEventListener("dragover",e=>{
e.preventDefault()
})


phone.addEventListener("drop",e=>{

e.preventDefault()

const type=e.dataTransfer.getData("type")

if(!pages[currentPage].blocks) pages[currentPage].blocks=[]

pages[currentPage].blocks.push({type})

renderPhone()

})


async function save(){

await fetch("/admin/save-builder",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({
puzzleId:"<%= puzzle._id %>",
pages
})

})

alert("Opgeslagen!")

}


renderPages()
renderPhone()

</script>
